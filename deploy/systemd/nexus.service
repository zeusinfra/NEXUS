[Unit]
Description=NEXUS Cognitive OS - Headless Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/nexus/Documentos/NEXUS/NEXUS
ExecStart=/home/nexus/Documentos/NEXUS/NEXUS/.venv/bin/python -m apps.web_gui --headless
Restart=always
RestartSec=10
StandardOutput=append:/home/nexus/Documentos/NEXUS/NEXUS/logs/systemd_out.log
StandardError=append:/home/nexus/Documentos/NEXUS/NEXUS/logs/systemd_err.log

[Install]
WantedBy=default.target
