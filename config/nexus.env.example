# Secrets and runtime overrides for /etc/nexus/nexus.env.
# Do not commit real keys.
NEXUS_CLOUD_PROVIDER=ollama
NEXUS_CLOUD_MODEL=gemma4:31b-cloud
NEXUS_CLOUD_API_KEY=
NEXUS_LOCAL_PROVIDER=ollama
NEXUS_LOCAL_ENDPOINT=http://localhost:11434
NEXUS_LOCAL_MODEL=auto
NEXUS_AUTONOMY_LEVEL=GUARDED

# Optional UI accent override. Leave empty to follow KDE/GNOME/GTK system color.
NEXUS_SYSTEM_ACCENT_COLOR=

# Voice/TTS
# auto = pt-BR neural first, then local Piper/Kokoro fallback.
# local = offline Piper/Kokoro only. none = disables synthesis engine.
NEXUS_TTS_ENGINE=auto
NEXUS_TTS_EDGE_VOICE=pt-BR-AntonioNeural
NEXUS_TTS_EDGE_RATE=+0%
NEXUS_TTS_EDGE_VOLUME=+0%
NEXUS_TTS_EDGE_PITCH=+0Hz
NEXUS_TTS_PIPER_MODEL=models/piper/pt_BR_maria_low.onnx
NEXUS_KOKORO_VOICE=pm_alex
NEXUS_KOKORO_LANG=pt-br
NEXUS_ASR_MODEL=small
NEXUS_ASR_DEVICE=cpu
NEXUS_ASR_COMPUTE_TYPE=int8
