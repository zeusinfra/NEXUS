# ZEUS Environment Variables Example
# Copy this file to .env and fill in your keys

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Ollama Configuration (Local)
ZEUS_LLM_URL=http://127.0.0.1:11434/api/chat
ZEUS_LLM_MODEL=gemma4:31b-cloud
ZEUS_EMBEDDING_MODEL=nomic-embed-text
ZEUS_DISABLE_OLLAMA=0

# Security & Network
ZEUS_JWT_SECRET=your_jwt_secret_here
ZEUS_MOBILE_TOKEN=your_mobile_token_here
ZEUS_ALLOW_LAN=1
ZEUS_DISABLE_SSL=1
ZEUS_LAN_AUTH=0

# System Settings
ZEUS_MAX_PROMPT_CHARS=16000
ZEUS_ENABLE_VOICE_SENSING=0
