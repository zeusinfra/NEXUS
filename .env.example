# NEXUS Environment Variables Example
# Copy this file to .env and fill in your keys

# LLM Configuration
# Profiles: local (default), lan (remote access), prod/production (strict boot checks)
NEXUS_ENV=local
NEXUS_LLM_PROVIDER=ollama
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Ollama Configuration (Cloud via local Ollama daemon)
# Run `ollama signin` once on this machine, then use the local API below.
NEXUS_LLM_URL=http://127.0.0.1:11434/api/chat
NEXUS_LLM_MODEL=gemma4:31b-cloud
NEXUS_LLM_FAST_MODEL=
NEXUS_LLM_HEAVY_MODEL=
NEXUS_LLM_FAST_MAX_CHARS=3500
OLLAMA_API_KEY=your_ollama_api_key_here
NEXUS_EMBEDDING_MODEL=nomic-embed-text
NEXUS_DISABLE_OLLAMA=0
NEXUS_PREFER_OLLAMA=1

# Security & Network
NEXUS_JWT_SECRET=replace_with_at_least_32_random_chars
NEXUS_ALLOW_INSECURE_DEV_SECRET=0
NEXUS_ALLOW_LAN=0
NEXUS_LAN_TOKEN=replace_with_at_least_16_random_chars_when_lan_enabled
NEXUS_DISABLE_SSL=1
NEXUS_LAN_AUTH=1
NEXUS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# System Settings
NEXUS_MAX_PROMPT_CHARS=16000
NEXUS_MAX_CHAT_MESSAGE_CHARS=16000
NEXUS_MAX_WEB_CONTEXT_CHARS=50000
NEXUS_MAX_VISION_IMAGE_BYTES=6291456
NEXUS_ENABLE_VOICE_SENSING=0
NEXUS_ENABLE_BROWSER_SENSING=0
NEXUS_ENABLE_INTERNAL_WATCHER=0
NEXUS_ENABLE_AUTONOMOUS_TASKS=0
NEXUS_ENABLE_BOOT_GREETING=0
NEXUS_ENABLE_RESOURCE_MONITOR=0
NEXUS_ENABLE_SECOND_BRAIN=0
NEXUS_ENABLE_SECOND_BRAIN_SYNC_ENGINE=0
NEXUS_ENABLE_OBSIDIAN_AUTO_SYNC=0
NEXUS_ENABLE_NOTION_AUTO_SYNC=0
NEXUS_ENABLE_LINEAR_AUTO_SYNC=0
NEXUS_LOW_MEM_AUTO=1
NEXUS_AGENT_PROGRESS_EVENTS=1
NEXUS_TOOL_EXECUTION_MODE=confirm
# Interpreter execution flags such as `python3 -c`, `python3 -m`, and `node -e`
# require explicit confirmation even when the executable is allowlisted.
NEXUS_CMD_ALLOWLIST=ls,pwd,echo,cat,sed,rg,find,wc,python3,node,npm,cargo,git
NEXUS_EXECUTION_MODE=manual
NEXUS_EXECUTION_SANDBOX=0
NEXUS_SANDBOX_ENGINE=auto
NEXUS_SANDBOX_IMAGE=python:3.12-slim
NEXUS_SANDBOX_NETWORK=none
NEXUS_SANDBOX_MOUNT_MODE=rw
NEXUS_ALLOWED_EDIT_PATHS=/home/nexus/Documentos/NEXUS/NEXUS,/home/nexus/Documentos/Brain,/tmp/nexus_

# Second Brain Architecture Integrations
NEXUS_VAULT_PATH=/home/nexus/Documentos/Brain
NEXUS_DB_PATH=./nexus_events.db
NEXUS_MEMORY_SERVICE_URL=http://127.0.0.1:8085/health
NEXUS_SQLITE_BUSY_TIMEOUT_SEC=5

# Notion
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here


# Linear
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
LINEAR_WORKSPACE_ID=your_linear_workspace_id_here

# Cognitive Loop (Autonomous Brain)
NEXUS_COGNITIVE_LOOP_ENABLED=0
NEXUS_COGNITIVE_LOOP_INTERVAL_SEC=30
NEXUS_COGNITIVE_LOOP_MODE=safe

# Feature Flags
NEXUS_ENABLE_NOTION=false
NEXUS_ENABLE_LINEAR=false
NEXUS_ENABLE_VECTOR_MEMORY=false
NEXUS_WATCHER_DEBOUNCE_MS=1200

# Arquitetura de Amplificacao Adaptativa
NEXUS_MODE=BALANCED

NEXUS_COGNITIVE_INTERVAL_IDLE=60
NEXUS_COGNITIVE_INTERVAL_DEFAULT=20
NEXUS_COGNITIVE_INTERVAL_ACTIVE=10
NEXUS_COGNITIVE_INTERVAL_CRITICAL=5
NEXUS_COGNITIVE_INTERVAL_ADMIN=8
NEXUS_COGNITIVE_INTERVAL_SELF_IMPROVEMENT=10
NEXUS_COGNITIVE_INTERVAL_LOW_RESOURCE=90

NEXUS_MAX_STEPS_DEFAULT=6
NEXUS_MAX_STEPS_COMPLEX=12
NEXUS_MAX_STEPS_CRITICAL=16
NEXUS_MAX_STEPS_ADMIN=14
NEXUS_MAX_STEPS_SELF_IMPROVEMENT=18

NEXUS_CONTEXT_BUDGET_CHARS=32000
NEXUS_CONTEXT_SUMMARY_ENABLED=true
NEXUS_CONTEXT_COMPRESSION_RATIO=0.35
NEXUS_CONTEXT_DEDUP_ENABLED=true
NEXUS_TOPIC_TRACKING_ENABLED=true
NEXUS_RESPONSE_SANITIZER_ENABLED=true

NEXUS_AUTONOMY_LEVEL=GUARDED
NEXUS_ADMIN_AUTONOMY_ENABLED=true
NEXUS_SUDO_BROKER_ENABLED=true
NEXUS_ROOT_DAEMON_ENABLED=false
NEXUS_REQUIRE_CONFIRMATION_FOR_HIGH_RISK=true
NEXUS_ALLOW_SAFE_AUTOFIX=true
NEXUS_ALLOW_SELF_IMPROVEMENT=true
NEXUS_SELF_IMPROVEMENT_AUTO_APPLY_LOW_RISK=true

NEXUS_CPU_SOFT_LIMIT=65
NEXUS_RAM_SOFT_LIMIT=75
NEXUS_SWAP_SOFT_LIMIT=50
NEXUS_DISK_MIN_FREE_PERCENT=10
NEXUS_TOKEN_BUDGET_MODE=adaptive

NEXUS_AUDIT_LOG_ENABLED=true
NEXUS_BACKUP_BEFORE_ADMIN_ACTION=true
NEXUS_BACKUP_BEFORE_SELF_PATCH=true

NEXUS_SENTRY_ENABLED=false
SENTRY_DSN=
NEXUS_SENTRY_TRACES_SAMPLE_RATE=0
NEXUS_RELEASE=local
