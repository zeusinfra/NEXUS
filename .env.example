# ZEUS Environment Variables Example
# Copy this file to .env and fill in your keys

# LLM Configuration
# Profiles: local (default), lan (remote access), prod/production (strict boot checks)
ZEUS_ENV=local
ZEUS_LLM_PROVIDER=ollama
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Ollama Configuration (Cloud via local Ollama daemon)
# Run `ollama signin` once on this machine, then use the local API below.
ZEUS_LLM_URL=http://127.0.0.1:11434/api/chat
ZEUS_LLM_MODEL=gemma4:31b-cloud
OLLAMA_API_KEY=your_ollama_api_key_here
ZEUS_EMBEDDING_MODEL=nomic-embed-text
ZEUS_DISABLE_OLLAMA=0
ZEUS_PREFER_OLLAMA=1

# Security & Network
ZEUS_JWT_SECRET=replace_with_at_least_32_random_chars
ZEUS_ALLOW_INSECURE_DEV_SECRET=0
ZEUS_ALLOW_LAN=0
ZEUS_LAN_TOKEN=replace_with_at_least_16_random_chars_when_lan_enabled
ZEUS_DISABLE_SSL=1
ZEUS_LAN_AUTH=1
ZEUS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# System Settings
ZEUS_MAX_PROMPT_CHARS=16000
ZEUS_MAX_CHAT_MESSAGE_CHARS=16000
ZEUS_MAX_WEB_CONTEXT_CHARS=50000
ZEUS_MAX_VISION_IMAGE_BYTES=6291456
ZEUS_ENABLE_VOICE_SENSING=0
ZEUS_ENABLE_BROWSER_SENSING=0
ZEUS_ENABLE_INTERNAL_WATCHER=0
ZEUS_ENABLE_AUTONOMOUS_TASKS=0
ZEUS_ENABLE_BOOT_GREETING=0
ZEUS_ENABLE_RESOURCE_MONITOR=0
ZEUS_ENABLE_SECOND_BRAIN=0
ZEUS_ENABLE_SECOND_BRAIN_SYNC_ENGINE=0
ZEUS_ENABLE_OBSIDIAN_AUTO_SYNC=0
ZEUS_ENABLE_NOTION_AUTO_SYNC=0
ZEUS_ENABLE_LINEAR_AUTO_SYNC=0
ZEUS_LOW_MEM_AUTO=1
ZEUS_AGENT_PROGRESS_EVENTS=1
ZEUS_TOOL_EXECUTION_MODE=confirm
# Interpreter execution flags such as `python3 -c`, `python3 -m`, and `node -e`
# require explicit confirmation even when the executable is allowlisted.
ZEUS_CMD_ALLOWLIST=ls,pwd,echo,cat,sed,rg,find,wc,python3,node,npm,cargo,git
ZEUS_ALLOWED_EDIT_PATHS=/home/zeus/Documentos/ZEUS_SYSTEM,/home/zeus/Documentos/Brain,/tmp/zeus_

# Second Brain Architecture Integrations
ZEUS_VAULT_PATH=/home/zeus/Documentos/Brain
ZEUS_DB_PATH=./zeus_events.db

# Notion
NOTION_TOKEN=your_notion_token_here
NOTION_DATABASE_ID=your_notion_database_id_here


# Linear
LINEAR_API_KEY=your_linear_api_key_here
LINEAR_TEAM_ID=your_linear_team_id_here
LINEAR_WORKSPACE_ID=your_linear_workspace_id_here

# Cognitive Loop (Autonomous Brain)
ZEUS_COGNITIVE_LOOP_ENABLED=0
ZEUS_COGNITIVE_LOOP_INTERVAL_SEC=30
ZEUS_COGNITIVE_LOOP_MODE=safe

# Feature Flags
ZEUS_ENABLE_NOTION=false
ZEUS_ENABLE_LINEAR=false
ZEUS_ENABLE_VECTOR_MEMORY=false
ZEUS_WATCHER_DEBOUNCE_MS=1200

# Arquitetura de Amplificacao Adaptativa
ZEUS_MODE=BALANCED

ZEUS_COGNITIVE_INTERVAL_IDLE=60
ZEUS_COGNITIVE_INTERVAL_DEFAULT=20
ZEUS_COGNITIVE_INTERVAL_ACTIVE=10
ZEUS_COGNITIVE_INTERVAL_CRITICAL=5
ZEUS_COGNITIVE_INTERVAL_ADMIN=8
ZEUS_COGNITIVE_INTERVAL_SELF_IMPROVEMENT=10
ZEUS_COGNITIVE_INTERVAL_LOW_RESOURCE=90

ZEUS_MAX_STEPS_DEFAULT=6
ZEUS_MAX_STEPS_COMPLEX=12
ZEUS_MAX_STEPS_CRITICAL=16
ZEUS_MAX_STEPS_ADMIN=14
ZEUS_MAX_STEPS_SELF_IMPROVEMENT=18

ZEUS_CONTEXT_BUDGET_CHARS=32000
ZEUS_CONTEXT_SUMMARY_ENABLED=true
ZEUS_CONTEXT_COMPRESSION_RATIO=0.35
ZEUS_CONTEXT_DEDUP_ENABLED=true
ZEUS_TOPIC_TRACKING_ENABLED=true
ZEUS_RESPONSE_SANITIZER_ENABLED=true

ZEUS_AUTONOMY_LEVEL=GUARDED
ZEUS_ADMIN_AUTONOMY_ENABLED=true
ZEUS_SUDO_BROKER_ENABLED=true
ZEUS_ROOT_DAEMON_ENABLED=false
ZEUS_REQUIRE_CONFIRMATION_FOR_HIGH_RISK=true
ZEUS_ALLOW_SAFE_AUTOFIX=true
ZEUS_ALLOW_SELF_IMPROVEMENT=true
ZEUS_SELF_IMPROVEMENT_AUTO_APPLY_LOW_RISK=true

ZEUS_CPU_SOFT_LIMIT=65
ZEUS_RAM_SOFT_LIMIT=75
ZEUS_SWAP_SOFT_LIMIT=50
ZEUS_DISK_MIN_FREE_PERCENT=10
ZEUS_TOKEN_BUDGET_MODE=adaptive

ZEUS_AUDIT_LOG_ENABLED=true
ZEUS_BACKUP_BEFORE_ADMIN_ACTION=true
ZEUS_BACKUP_BEFORE_SELF_PATCH=true
