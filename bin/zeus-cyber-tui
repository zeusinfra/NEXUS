CLIENT_ID = os.getenv("ZEUS_TUI_CLIENT_ID", "zeus_cyber_tui").strip() or "zeus_cyber_tui"
SESSION_ID = os.getenv("ZEUS_TUI_SESSION_ID") or datetime.now().strftime("tui-%Y%m%d-%H%M%S")
VERSION = "1.14.46"
SHELL_TIMEOUT = 30  # segundos max por comando shell

