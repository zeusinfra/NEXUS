def _ensure_tui_deps() -> None:
    try:
        import textual  # noqa: F401
        import rich  # noqa: F401
        return
    except ImportError:
        pass

    root = Path(__file__).resolve().parents[1]
    candidates = [
        os.getenv("ZEUS_TUI_PYTHON"),
        str(root / ".venv" / "bin" / "python"),
        sys.executable,
    ]
    current = str(Path(sys.executable).resolve())
    for candidate in candidates:
        if not candidate:
            continue
        path = Path(candidate)
        if not path.exists():
            continue
        if str(path.resolve()) == current:
            continue
        os.execv(str(path), [str(path), __file__, *sys.argv[1:]])

    print("Textual nao encontrado. Instale as dependencias ou rode via .venv.")
    raise SystemExit(1)

_ensure_tui_deps()

