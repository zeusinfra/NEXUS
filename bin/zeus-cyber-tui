# ──────────────────────── HTTP helpers ────────────────────────

def _json_request(method: str, path: str, payload: dict | None = None, timeout: float = 30.0) -> dict:
    body = None
    headers = {"X-Zeus-Client-Id": CLIENT_ID}
    if payload is not None:
        body = json.dumps(payload).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(BACKEND + path, data=body, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            raw = response.read().decode("utf-8")
        return json.loads(raw or "{}")
    except Exception as e:
        return {"error": str(e)}

def _get_json(path: str, timeout: float = 5.0) -> dict:
    return _json_request("GET", path, timeout=timeout)

def _post_json(path: str, payload: dict, timeout: float = 120.0) -> dict:
    return _json_request("POST", path, payload=payload, timeout=timeout)

def _fetch_status() -> dict:
    """Fetch backend status once. Returns a dict with model/provider/cpu/ram."""
    try:
        data = _get_json("/api/applet/status", timeout=2.5)
        llm = data.get("llm") or {}
        perception = data.get("perception") or {}
        system = perception.get("system") or {}
        return {
            "model": llm.get("model", "unknown"),
            "provider": str(llm.get("provider", "unknown")).capitalize(),
            "cpu": system.get("cpu_percent", 0),
            "ram": system.get("ram_percent", 0),
            "online": True,
        }
    except Exception:
        return {"model": "unknown", "provider": "Offline", "cpu": 0, "ram": 0, "online": False}

def _run_shell(cmd: str, timeout: int = SHELL_TIMEOUT) -> tuple[int, str, str]:
    """Executa um comando shell e retorna (returncode, stdout, stderr)."""
    try:
        proc = subprocess.run(
            cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=timeout,
            cwd=str(Path.home()),
        )
        return proc.returncode, proc.stdout, proc.stderr
    except subprocess.TimeoutExpired:
        return -1, "", f"Timeout ({timeout}s)"
    except Exception as e:
        return -1, "", str(e)


SLASH_HELP = """
[bold #00ffcc]Comandos disponíveis:[/]

  [bold yellow]!comando[/]          Executa comando shell direto (ex: [dim]!ls -la[/dim])
  [bold yellow]/help[/]             Mostra esta ajuda
  [bold yellow]/sysinfo[/]          Info do sistema (hostname, kernel, uptime, disco)
  [bold yellow]/services[/]         Lista serviços systemd ativos
  [bold yellow]/logs[/]             Últimas 30 linhas do journal do ZEUS
  [bold yellow]/logs N[/]           Últimas N linhas do journal
  [bold yellow]/procs[/]            Top 10 processos por uso de CPU
  [bold yellow]/net[/]              Interfaces de rede e IPs
  [bold yellow]/disk[/]             Uso de disco por partição
  [bold yellow]/who[/]              Quem está logado
  [bold yellow]/env VAR[/]          Mostra variável de ambiente
  [bold yellow]/clear[/]            Limpa o log
  [bold yellow]/quit[/]             Sai da TUI
""".strip()

# ──────────────────────── Greeting Screen ────────────────────────

class GreetingScreen(Screen):
    """Estado 1: Tela inicial com Logo, Input flutuante e status."""

    BINDINGS = [
        Binding("ctrl+c", "quit", "Quit"),
        Binding("ctrl+l", "clear", "Clear"),
    ]

    def compose(self) -> ComposeResult:
        with Middle(id="greeting-container"):
            yield Static(LOGO, id="logo", markup=True)
            yield Static(SUBTITLE, id="subtitle", markup=True)
            yield Center(Input(placeholder='Ask anything... "What is the tech stack of this project?"', id="greet-input"))
            yield Static("[dim]Build · Connecting...[/dim]", id="build-info", markup=True)
            yield Static("[dim]tab[/dim] agents   [dim]ctrl+p[/dim] commands", id="hints", markup=True)
            yield Static("● [yellow]Tip[/yellow] Press [bold]Ctrl+C[/bold] when typing to clear the input field", id="tip", markup=True)

    def on_mount(self) -> None:
        self.query_one("#greet-input").focus()
        self.fetch_status()

    @work(thread=True)
    def fetch_status(self) -> None:
        status = _fetch_status()
        if status["online"]:
            text = f"[#00aaff]Build[/] · [bold]{status['model']}[/bold] {status['provider']}"
        else:
            text = "[#00aaff]Build[/] · [red]Backend Offline[/red]"
        self.app.call_from_thread(self._update_build, text)

    def _update_build(self, text: str) -> None:
        try:
            self.query_one("#build-info", Static).update(text)
        except Exception:
            pass

    def on_input_submitted(self, event: Input.Submitted) -> None:
        msg = event.value.strip()
        if msg:
            chat_screen = ChatScreen(initial_message=msg)
            self.app.push_screen(chat_screen)

# ──────────────────────── Chat Screen ────────────────────────

class ChatScreen(Screen):
    """Estado 2: Tela de chat com header, log rolável, footer de telemetria e input fixo."""

    BINDINGS = [
        Binding("ctrl+c", "quit", "Quit"),
        Binding("ctrl+l", "clear_log", "Clear Log"),
    ]

    def __init__(self, initial_message: str = "") -> None:
        super().__init__()
        self.initial_message = initial_message

    def compose(self) -> ComposeResult:
        yield Static(f"ZEUS Ops · {SESSION_ID}", id="chat-header", markup=True)
        yield RichLog(id="chat-log", highlight=True, markup=True, auto_scroll=True, max_lines=5000)
        with Container(id="chat-input-bar"):
            yield Static("[dim]  !cmd  shell  │  /help  comandos  │  Enter  envia para IA[/dim]", id="input-hint", markup=True)
            yield Input(placeholder="Message ZEUS...", id="chat-input")
        with Horizontal(id="chat-footer"):
            yield Static(f"[dim]session[/dim] {SESSION_ID}", id="chat-footer-left", markup=True)
            yield Static(f"[dim]cpu[/dim] --%  [dim]ram[/dim] --% ", id="chat-footer-right", markup=True)

    def on_mount(self) -> None:
        self.log_widget = self.query_one("#chat-log", RichLog)
        self.input_widget = self.query_one("#chat-input", Input)
        self.input_widget.focus()
        self.seen_events: set[str] = set()

        # Start background workers
        self.poll_events()
        self.poll_telemetry()

        if self.initial_message:
            self.submit_message(self.initial_message)

    def action_clear_log(self) -> None:
        self.log_widget.clear()

    # ── Telemetry Polling ──

    @work(exclusive=True, thread=True)
    def poll_telemetry(self) -> None:
        """Atualiza CPU/RAM no footer a cada 3 segundos."""
        while True:
            time.sleep(3.0)
            status = _fetch_status()
            if status["online"]:
                footer_text = f"[dim]cpu[/dim] {status['cpu']}%  [dim]ram[/dim] {status['ram']}% "
                header_text = f"[bold #00ffcc]ZEUS[/] Ops · {status['model']} · [dim]{status['provider']}[/dim]"
            else:
                footer_text = "[dim]cpu[/dim] [red]--[/]%  [dim]ram[/dim] [red]--[/]% "
                header_text = f"[bold #00ffcc]ZEUS[/] Ops · [red]Offline[/red]"
            self.app.call_from_thread(self._update_bars, header_text, footer_text)

    def _update_bars(self, header: str, footer: str) -> None:
        try:
            self.query_one("#chat-header", Static).update(header)
            self.query_one("#chat-footer-right", Static).update(footer)
        except Exception:
            pass

    # ── Event Polling ──

    @work(exclusive=True, thread=True, group="events")
    def poll_events(self) -> None:
        """Drena eventos do backend em loop para renderizar progresso de agentes e tools."""
        while True:
            time.sleep(1.0)
            try:
                query = urllib.parse.urlencode({"client_id": CLIENT_ID})
                data = _get_json(f"/api/events/drain?{query}", timeout=2.0)
                events = data.get("events") or []
                for event in events:
                    if not isinstance(event, dict):
                        continue
                    sig = json.dumps({
                        "type": event.get("type"),
                        "stage": event.get("stage"),
                        "tool": event.get("tool"),
                        "text": (event.get("text") or "")[:80],
                        "id": event.get("id") or event.get("client_msg_id"),
                    }, sort_keys=True)
                    if sig in self.seen_events:
                        continue
                    self.seen_events.add(sig)
                    if len(self.seen_events) > 500:
                        self.seen_events.clear()
                    self.app.call_from_thread(self._render_event, event)
            except Exception:
                pass

    def _render_event(self, event: dict) -> None:
        evt_type = event.get("type")

        # ── Respostas da IA que chegam via evento (streaming) ──
        if evt_type == "CHAT_AI":
            msg = event.get("message") or event.get("text") or ""
            if msg.strip():
                self.log_widget.write("")
                self.log_widget.write(f"  [bold #00ffcc]▎ ZEUS[/]")
                for line in msg.strip().split("\n"):
                    self.log_widget.write(f"  {line}")
                self.log_widget.write("")
            return

        # ── Progresso do agente ──
        if evt_type == "AGENT_PROGRESS":
            stage = event.get("stage", "progress")
            text = event.get("text", stage)
            if stage in {"step_started"}:
                self.log_widget.write(f"  [dim #00bbaa]⟐ {text}[/]")
            elif stage in {"completed", "chat_completed"}:
                self.log_widget.write(f"  [#00ffcc]✓ {text}[/]")
            else:
                self.log_widget.write(f"  [#00ddaa]● {text}[/]")
        elif evt_type == "TOOL_LOG":
            tool = event.get("tool", "tool")
            stage = str(event.get("stage", "")).replace("_", " ").upper()
            error = event.get("error")
            if error:
                self.log_widget.write(f"  [red]✗ TOOL {tool}:[/red] {error}")
            else:
                res = event.get("result") or event.get("args") or stage
                if isinstance(res, dict):
                    keys = ", ".join(list(res.keys())[:6])
                    res = keys or "ok"
                self.log_widget.write(f"  [#bb88ff]› {tool}[/] [dim]{stage}[/dim] {res}")
        elif evt_type == "SYSTEM_ALERT":
            msg = event.get("message", "Alerta")
            self.log_widget.write(Panel(msg, title="⚠ ALERTA", border_style="red"))

        # ── Qualquer outro evento desconhecido — mostra para não perder info ──
        else:
            text = event.get("text") or event.get("message") or ""
            if text.strip():
                self.log_widget.write(f"  [dim]{evt_type}: {text.strip()[:200]}[/dim]")

    # ── Chat I/O ──

    def submit_message(self, text: str) -> None:
        self.log_widget.write("")
        self.log_widget.write(f"  [bold blue]▎ VOCE[/]")
        self.log_widget.write(f"  {text}")
        self.log_widget.write("")
        self.send_to_backend(text)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        msg = event.value.strip()
        if not msg:
            return
        self.input_widget.value = ""

        # ── Shell commands (!comando) ──
        if msg.startswith("!"):
            shell_cmd = msg[1:].strip()
            if shell_cmd:
                self.log_widget.write("")
                self.log_widget.write(f"  [bold yellow]$ {shell_cmd}[/]")
                self.run_shell_command(shell_cmd)
            return

        # ── Slash commands (/xxx) ──
        if msg.startswith("/"):
            self._handle_slash(msg)
            return

        # ── Normal chat → envia para IA ──
        self.submit_message(msg)

    def _handle_slash(self, cmd: str) -> None:
        parts = cmd.strip().split(None, 1)
        base = parts[0].lower()
        arg = parts[1] if len(parts) > 1 else ""

        if base == "/help":
            self.log_widget.write(SLASH_HELP)
        elif base == "/clear":
            self.log_widget.clear()
        elif base in {"/quit", "/exit"}:
            self.app.exit()
        elif base == "/sysinfo":
            self.run_shell_command(
                'echo "Hostname: $(hostname)" && '
                'echo "Kernel:   $(uname -r)" && '
                'echo "Uptime:  $(uptime -p)" && '
                'echo "Arch:     $(uname -m)" && '
                'echo "" && lsb_release -ds 2>/dev/null || cat /etc/os-release 2>/dev/null | head -2'
            )
        elif base == "/services":
            self.run_shell_command("systemctl list-units --type=service --state=running --no-pager --no-legend | head -25")
        elif base == "/logs":
            n = arg.strip() if arg.strip().isdigit() else "30"
            self.run_shell_command(f"journalctl --user -u zeus -n {n} --no-pager 2>/dev/null || journalctl -u zeus -n {n} --no-pager 2>/dev/null || echo 'zeus.service not found in journal'")
        elif base == "/procs":
            self.run_shell_command("ps aux --sort=-%cpu | head -11")
        elif base == "/net":
            self.run_shell_command("ip -br addr show 2>/dev/null || ifconfig 2>/dev/null || echo 'Sem informacao de rede'")
        elif base == "/disk":
            self.run_shell_command("df -h --type=ext4 --type=btrfs --type=xfs --type=vfat 2>/dev/null || df -h | grep -E '^/dev'")
        elif base == "/who":
            self.run_shell_command("who && echo '' && w")
        elif base == "/env":
            if arg:
                val = os.environ.get(arg.strip(), "[red]não definida[/red]")
                self.log_widget.write(f"  [dim]{arg}[/dim] = {val}")
            else:
                self.log_widget.write("  [yellow]Uso: /env NOME_VARIAVEL[/yellow]")
        else:
            self.log_widget.write(f"  [red]Comando desconhecido:[/red] {base}  [dim](use /help)[/dim]")

    @work(thread=True)
    def run_shell_command(self, cmd: str) -> None:
        """Executa comando no shell real e exibe stdout/stderr no log."""
        code, stdout, stderr = _run_shell(cmd)
        def _write():
            if stdout.strip():
                for line in stdout.strip().split("\n"):
                    self.log_widget.write(f"  {line}")
            if stderr.strip():
                for line in stderr.strip().split("\n"):
                    self.log_widget.write(f"  [red]{line}[/red]")
            if code != 0:
                self.log_widget.write(f"  [dim red]exit code {code}[/dim red]")
            self.log_widget.write("")
        self.app.call_from_thread(_write)

    @work(thread=True)
    def send_to_backend(self, text: str) -> None:
        started = time.perf_counter()
        msg_id = str(uuid.uuid4())
        payload = {
            "message": text,
            "source": "cyber_tui",
            "client_id": CLIENT_ID,
            "session_id": SESSION_ID,
            "client_msg_id": msg_id,
        }

        # Mostrar indicador de "pensando"
        self.app.call_from_thread(self.log_widget.write, "  [dim #00ffcc]◌ ZEUS pensando...[/]")

        data = _post_json("/api/applet/chat", payload, timeout=180.0)

        reply = str(data.get("reply") or data.get("error") or "Sem resposta.")
        latency_ms = data.get("latency_ms") or round((time.perf_counter() - started) * 1000)

        def _write_reply():
            self.log_widget.write("")
            self.log_widget.write(f"  [bold #00ffcc]▎ ZEUS[/] [dim]· {latency_ms}ms[/dim]")
            # Renderizar resposta com quebra de linha para linhas longas
            for line in reply.split("\n"):
                self.log_widget.write(f"  {line}")
            self.log_widget.write("")

        self.app.call_from_thread(_write_reply)

# ──────────────────────── App ────────────────────────

class ZeusCyberApp(App):
    """ZEUS Cognitive TUI — Full-Screen Modern Interface."""

    TITLE = "ZEUS"
    CSS = CSS

    def on_mount(self) -> None:
        self.push_screen(GreetingScreen())

if __name__ == "__main__":
    app = ZeusCyberApp()
    app.run()
