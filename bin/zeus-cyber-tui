  [bold yellow]/clear[/]            Limpa o log
  [bold yellow]/quit[/]             Sai da TUI
""".strip()

# ──────────────────────── Greeting Screen ────────────────────────

class GreetingScreen(Screen):
    """Estado 1: Tela inicial com Logo, Input flutuante e status."""

    BINDINGS = [
        Binding("ctrl+c", "quit", "Quit"),
        Binding("ctrl+l", "clear", "Clear"),
    ]

    def compose(self) -> ComposeResult:
        with Middle(id="greeting-container"):
            yield Static(LOGO, id="logo", markup=True)
            yield Static(SUBTITLE, id="subtitle", markup=True)
            yield Static("[#00d9b8]Digite uma mensagem, comando local ou /help[/]", id="greet-input-label", markup=True)
            yield Center(Input(placeholder='Pergunte ao ZEUS ou digite /help', id="greet-input"))
            yield Static("[dim]Build · Connecting...[/dim]", id="build-info", markup=True)
            yield Static("[#6f7a89]Enter[/] envia  [#6f7a89]!cmd[/] shell  [#6f7a89]/status[/] telemetria", id="hints", markup=True)
            yield Static("[#d4a84f]Ctrl+C[/] sair   [#d4a84f]Ctrl+L[/] limpar", id="tip", markup=True)

    def on_mount(self) -> None:
        self.query_one("#greet-input").focus()
        self.fetch_status()

    @work(thread=True, group="greeting_status")
    def fetch_status(self) -> None:
        status = _fetch_status()
        if status["online"]:
            text = f"[#00aaff]Build[/] · [bold]{status['model']}[/bold] {status['provider']}"
        else:
            text = "[#00aaff]Build[/] · [red]Backend Offline[/red]"
        self.app.call_from_thread(self._update_build, text)

    def _update_build(self, text: str) -> None:
        try:
            self.query_one("#build-info", Static).update(text)
        except Exception:
            pass

    def on_input_submitted(self, event: Input.Submitted) -> None:
        msg = event.value.strip()
        if msg:
            event.input.value = ""
            chat_screen = ChatScreen(initial_message=msg)
            self.app.push_screen(chat_screen)

    def action_clear(self) -> None:
        try:
            self.query_one("#greet-input", Input).value = ""
        except Exception:
            pass

# ──────────────────────── Chat Screen ────────────────────────

class ChatScreen(Screen):
    """Estado 2: Tela de chat com header, log rolável, footer de telemetria e input fixo."""

    BINDINGS = [
        Binding("ctrl+c", "quit", "Quit"),
        Binding("ctrl+l", "clear_log", "Clear Log"),
    ]

    def __init__(self, initial_message: str = "") -> None:
        super().__init__()
        self.initial_message = initial_message
        self.running = False
        self.sending = False
        self.pending_reply_ids: set[str] = set()

    def compose(self) -> ComposeResult:
        yield Static(f"[bold #00ffcc]ZEUS[/] [#5fb3ff]Cyber TUI[/]  [dim]{SESSION_ID}[/dim]", id="chat-header", markup=True)
        yield RichLog(id="chat-log", highlight=True, markup=True, auto_scroll=True, max_lines=5000)
        with Container(id="chat-input-bar"):
            yield Static("[#d4a84f]!cmd[/] shell  [#8f7cff]/help[/] comandos  [#00d9b8]Enter[/] envia para IA", id="input-hint", markup=True)
            yield Input(placeholder="Mensagem para ZEUS...", id="chat-input")
        with Horizontal(id="chat-footer"):
            yield Static(f"[dim]session[/dim] {SESSION_ID}", id="chat-footer-left", markup=True)
            yield Static(f"[dim]cpu[/dim] --%  [dim]ram[/dim] --% ", id="chat-footer-right", markup=True)

    def on_mount(self) -> None:
        self.log_widget = self.query_one("#chat-log", RichLog)
        self.input_widget = self.query_one("#chat-input", Input)
        self.input_widget.focus()
        self.seen_events: set[str] = set()
        self.running = True

        # Start background workers
        self.poll_events()
        self.poll_telemetry()

        if self.initial_message:
            self.handle_message(self.initial_message)

    def action_clear_log(self) -> None:
        self.log_widget.clear()

    def on_unmount(self) -> None:
        self.running = False

    def _write_line(self, text: str = "") -> None:
        self.log_widget.write(text)

    def _write_block(self, text: str, style: str = "", indent: str = "  ") -> None:
        for line in text.splitlines() or [""]:
            safe = escape(line)
            self._write_line(f"{indent}[{style}]{safe}[/]" if style else f"{indent}{safe}")

    def _call_from_thread(self, callback, *args) -> bool:
        try:
            self.app.call_from_thread(callback, *args)
            return True
        except Exception:
            return False

    # ── Telemetry Polling ──

    @work(exclusive=True, thread=True, group="telemetry")
    def poll_telemetry(self) -> None:
        """Atualiza CPU/RAM no footer a cada 3 segundos."""
        worker = get_current_worker()
        while self.running and not worker.is_cancelled:
            for _ in range(30):
                if not self.running or worker.is_cancelled:
                    return
                time.sleep(0.1)
            if not self.running or worker.is_cancelled:
                return
            status = _fetch_status()
            if status["online"]:
                footer_text = f"[dim]cpu[/dim] {escape(str(status['cpu']))}%  [dim]ram[/dim] {escape(str(status['ram']))}% "
                header_text = f"[bold #00ffcc]ZEUS[/] Ops · {escape(str(status['model']))} · [dim]{escape(str(status['provider']))}[/dim]"
            else:
                footer_text = "[dim]cpu[/dim] [red]--[/]%  [dim]ram[/dim] [red]--[/]% "
                header_text = "[bold #00ffcc]ZEUS[/] Ops · [red]Offline[/red]"
            if not self._call_from_thread(self._update_bars, header_text, footer_text):
                return

    def _update_bars(self, header: str, footer: str) -> None:
        try:
            self.query_one("#chat-header", Static).update(header)
            self.query_one("#chat-footer-right", Static).update(footer)
        except Exception:
            pass

    # ── Event Polling ──

    @work(exclusive=True, thread=True, group="events")
    def poll_events(self) -> None:
        """Drena eventos do backend em loop para renderizar progresso de agentes e tools."""
        worker = get_current_worker()
        while self.running and not worker.is_cancelled:
            for _ in range(10):
                if not self.running or worker.is_cancelled:
                    return
                time.sleep(0.1)
            if not self.running or worker.is_cancelled:
                return
            try:
                query = urllib.parse.urlencode({"client_id": CLIENT_ID})
                data = _get_json(f"/api/events/drain?{query}", timeout=2.0)
                events = data.get("events") or []
                for event in events:
                    if not isinstance(event, dict):
                        continue
                    sig = json.dumps({
                        "type": event.get("type"),
                        "stage": event.get("stage"),
                        "tool": event.get("tool"),
                        "text": (event.get("text") or "")[:80],
                        "id": event.get("id") or event.get("client_msg_id"),
                    }, sort_keys=True)
                    if sig in self.seen_events:
                        continue
                    self.seen_events.add(sig)
                    if len(self.seen_events) > 500:
                        self.seen_events.clear()
                    if not self._call_from_thread(self._render_event, event):
                        return
            except Exception:
                pass

    def _render_event(self, event: dict) -> None:
        evt_type = event.get("type")

        # ── Respostas da IA que chegam via evento (streaming) ──
        if evt_type == "CHAT_AI":
            event_id = str(event.get("id") or (event.get("details") or {}).get("id") or "")
            if event_id and event_id in self.pending_reply_ids:
                return
            msg = event.get("message") or event.get("text") or ""
            if msg.strip():
                self.log_widget.write("")
                self.log_widget.write("  [bold #00ffcc]╭─ ZEUS[/]")
                self._write_block(msg.strip(), indent="  │ ")
                self.log_widget.write("  [#00ffcc]╰─[/]")
                self.log_widget.write("")
            return

        # ── Progresso do agente ──
        if evt_type == "AGENT_PROGRESS":
            stage = event.get("stage", "progress")
            text = event.get("text", stage)
            if stage in {"step_started"}:
                self.log_widget.write(f"  [dim #5fb3ff]◆ {escape(str(text))}[/]")
            elif stage in {"completed", "chat_completed"}:
                self.log_widget.write(f"  [#00d9b8]✓ {escape(str(text))}[/]")
            else:
                self.log_widget.write(f"  [#9aa6b7]• {escape(str(text))}[/]")
        elif evt_type == "TOOL_LOG":
            tool = event.get("tool", "tool")
            stage = str(event.get("stage", "")).replace("_", " ").upper()
            error = event.get("error")
            if error:
                self.log_widget.write(f"  [red]✗ tool:{escape(str(tool))}[/red] {escape(str(error))}")
            else:
                res = event.get("result") or event.get("args") or stage
                if isinstance(res, dict):
                    keys = ", ".join(list(res.keys())[:6])
                    res = keys or "ok"
                self.log_widget.write(f"  [#8f7cff]› {escape(str(tool))}[/] [dim]{escape(stage)}[/dim] {escape(str(res))}")
        elif evt_type == "SYSTEM_ALERT":
            msg = event.get("message", "Alerta")
            self.log_widget.write(Panel(escape(str(msg)), title="⚠ ALERTA", border_style="red"))

        # ── Qualquer outro evento desconhecido — mostra para não perder info ──
        else:
            text = event.get("text") or event.get("message") or ""
            if text.strip():
                self.log_widget.write(f"  [dim]{escape(str(evt_type))}: {escape(text.strip()[:200])}[/dim]")

    # ── Chat I/O ──

    def handle_message(self, msg: str) -> None:
        if msg.startswith("!"):
            shell_cmd = msg[1:].strip()
            if shell_cmd:
                self.log_widget.write("")
                self.log_widget.write(f"  [bold yellow]$ {escape(shell_cmd)}[/]")
                self.run_shell_command(shell_cmd)
            return

        if msg.startswith("/"):
            self._handle_slash(msg)
            return

        self.submit_message(msg)

    def submit_message(self, text: str) -> None:
        if self.sending:
            self.log_widget.write("  [yellow]Envio pausado: aguarde a resposta atual terminar.[/yellow]")
            return

        self.log_widget.write("")
        self.log_widget.write("  [bold #5fb3ff]╭─ VOCE[/]")
        self._write_block(text, indent="  │ ")
        self.log_widget.write("  [#5fb3ff]╰─[/]")
        self.log_widget.write("")
        self.send_to_backend(text)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        msg = event.value.strip()
        if not msg:
            return
        self.input_widget.value = ""
        self.handle_message(msg)

    def _handle_slash(self, cmd: str) -> None:
        parts = cmd.strip().split(None, 1)
        base = parts[0].lower()
        arg = parts[1] if len(parts) > 1 else ""

        if base == "/help":
            self.log_widget.write(SLASH_HELP)
        elif base == "/clear":
            self.log_widget.clear()
        elif base in {"/quit", "/exit"}:
            self.app.exit()
        elif base == "/status":
            self.fetch_status_command()
        elif base == "/sysinfo":
            self.run_builtin_command(_system_summary)
        elif base == "/services":
            self.run_builtin_command(_service_lines)
        elif base == "/logs":
            n = arg.strip() if arg.strip().isdigit() else "30"
            self.run_builtin_command(lambda: _journal_lines(int(n)))
        elif base == "/procs":
            self.run_builtin_command(_process_lines)
        elif base == "/net":
            self.run_builtin_command(_network_lines)
        elif base == "/disk":
            self.run_builtin_command(_disk_lines)
        elif base == "/who":
            self.run_builtin_command(_who_lines)
        elif base == "/env":
            if arg:
                val = os.environ.get(arg.strip(), "nao definida")
                self.log_widget.write(f"  [dim]{escape(arg.strip())}[/dim] = {escape(val)}")
            else:
                self.log_widget.write("  [yellow]Uso: /env NOME_VARIAVEL[/yellow]")
        else:
            self.log_widget.write(f"  [red]Comando desconhecido:[/red] {escape(base)}  [dim](use /help)[/dim]")

    @work(thread=True, group="status_command")
    def fetch_status_command(self) -> None:
        status = _fetch_status()
        self._call_from_thread(self._write_status_result, status)

    def _write_status_result(self, status: dict) -> None:
        if status["online"]:
            self.log_widget.write(
                f"  [#00ffcc]Backend online[/] {escape(BACKEND)} · "
                f"{escape(str(status['model']))} / {escape(str(status['provider']))} · "
                f"cpu {escape(str(status['cpu']))}% ram {escape(str(status['ram']))}%"
            )
        else:
            self.log_widget.write(f"  [red]Backend offline[/red] {escape(status.get('error') or '')}")

    @work(thread=True, group="builtin_commands")
    def run_builtin_command(self, fn) -> None:
        code, stdout, stderr = fn()
        self._call_from_thread(self._write_command_result, code, stdout, stderr)

    @work(thread=True, group="shell_commands")
    def run_shell_command(self, cmd: str) -> None:
        """Executa comando no shell real e exibe stdout/stderr no log."""
        code, stdout, stderr = _run_user_shell(cmd)
        self._call_from_thread(self._write_command_result, code, stdout, stderr)

    def _write_command_result(self, code: int, stdout: str, stderr: str) -> None:
        if stdout.strip():
            self._write_block(stdout.strip())
        if stderr.strip():
            self._write_block(stderr.strip(), "red")
        if code != 0:
            self.log_widget.write(f"  [dim red]exit code {code}[/dim red]")
        self.log_widget.write("")

    @work(thread=True, group="chat_send")
    def send_to_backend(self, text: str) -> None:
        started = time.perf_counter()
        msg_id = str(uuid.uuid4())
        self.pending_reply_ids.add(msg_id)
        self.sending = True
        payload = {
            "message": text,
            "source": "cyber_tui",
            "client_id": CLIENT_ID,
            "session_id": SESSION_ID,
            "client_msg_id": msg_id,
        }

        self._call_from_thread(self._set_input_enabled, False)
        self._call_from_thread(self.log_widget.write, "  [dim #00ffcc]◌ ZEUS pensando...[/]")

        data = _post_json("/api/applet/chat", payload, timeout=180.0)

        reply = str(data.get("reply") or data.get("error") or "Sem resposta.")
        latency_ms = data.get("latency_ms") or round((time.perf_counter() - started) * 1000)

        def _write_reply():
            self.pending_reply_ids.discard(msg_id)
            self.sending = False
            self._set_input_enabled(True)
            self.log_widget.write("")
            self.log_widget.write(f"  [bold #00ffcc]╭─ ZEUS[/] [dim]· {latency_ms}ms[/dim]")
            self._write_block(reply, indent="  │ ")
            self.log_widget.write("  [#00ffcc]╰─[/]")
            self.log_widget.write("")

        self._call_from_thread(_write_reply)

    def _set_input_enabled(self, enabled: bool) -> None:
        try:
            self.input_widget.disabled = not enabled
            self.input_widget.placeholder = "Aguardando resposta do ZEUS..." if not enabled else "Mensagem para ZEUS..."
            if enabled:
                self.input_widget.focus()
        except Exception:
            pass

# ──────────────────────── App ────────────────────────

class ZeusCyberApp(App):
    """ZEUS Cognitive TUI — Full-Screen Modern Interface."""

    TITLE = "ZEUS"
    CSS = CSS

    def on_mount(self) -> None:
        self.push_screen(GreetingScreen())

if __name__ == "__main__":
    app = ZeusCyberApp()
    app.run()
