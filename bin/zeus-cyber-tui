# ──────────────────────── HTTP helpers ────────────────────────

def _json_request(method: str, path: str, payload: dict | None = None, timeout: float = 30.0) -> dict:
    body = None
    headers = {"X-Zeus-Client-Id": CLIENT_ID}
    if payload is not None:
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        headers["Content-Type"] = "application/json"
    req = urllib.request.Request(BACKEND + path, data=body, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as response:
            raw = response.read().decode("utf-8")
        try:
            data = json.loads(raw or "{}")
        except json.JSONDecodeError:
            return {"ok": False, "error": "Resposta HTTP nao era JSON.", "raw": raw[:1000]}
        if isinstance(data, dict):
            data.setdefault("ok", True)
            return data
        return {"ok": True, "data": data}
    except urllib.error.HTTPError as exc:
        try:
            raw = exc.read().decode("utf-8", errors="replace")
            detail = json.loads(raw).get("detail", raw)
        except Exception:
            detail = str(exc)
        return {"ok": False, "status": exc.code, "error": str(detail)}
    except Exception as e:
        return {"ok": False, "error": str(e)}

def _get_json(path: str, timeout: float = 5.0) -> dict:
    return _json_request("GET", path, timeout=timeout)

def _post_json(path: str, payload: dict, timeout: float = 120.0) -> dict:
    return _json_request("POST", path, payload=payload, timeout=timeout)

def _read_local_cpu_ram() -> tuple[float, float]:
    """Best-effort local telemetry fallback when backend omits system stats."""
    cpu = 0.0
    ram = 0.0
    try:
        import psutil  # type: ignore

        cpu = float(psutil.cpu_percent(interval=0.05))
        ram = float(psutil.virtual_memory().percent)
        return cpu, ram
    except Exception:
        pass

    try:
        stat = Path("/proc/stat").read_text().splitlines()[0].split()[1:]
        values = [float(v) for v in stat[:8]]
        idle = values[3] + (values[4] if len(values) > 4 else 0.0)
        total = sum(values)
        cpu = 0.0 if total <= 0 else max(0.0, min(100.0, 100.0 * (1.0 - idle / total)))
    except Exception:
        pass

    try:
        meminfo = {}
        for line in Path("/proc/meminfo").read_text().splitlines():
            key, raw = line.split(":", 1)
            meminfo[key] = float(raw.strip().split()[0])
        total = meminfo.get("MemTotal", 0.0)
        available = meminfo.get("MemAvailable", 0.0)
        ram = 0.0 if total <= 0 else max(0.0, min(100.0, 100.0 * (1.0 - available / total)))
    except Exception:
        pass

    return cpu, ram

def _coerce_percent(*values) -> float | None:
    for value in values:
        if value is None:
            continue
        try:
            return round(float(value), 1)
        except (TypeError, ValueError):
            continue
    return None

def _fetch_status() -> dict:
    """Fetch backend status once. Returns a dict with model/provider/cpu/ram."""
    data = _get_json("/api/applet/status", timeout=2.5)
    if data.get("error"):
        cpu, ram = _read_local_cpu_ram()
        return {"model": "unknown", "provider": "Offline", "cpu": cpu, "ram": ram, "online": False, "error": data["error"]}
    llm = data.get("llm") or {}
    perception = data.get("perception") or {}
    system = perception.get("system") or {}
    cpu = _coerce_percent(system.get("cpu_percent"), data.get("cpu_percent"), data.get("cpu"))
    ram = _coerce_percent(system.get("ram_percent"), data.get("ram_percent"), data.get("ram"))
    if cpu is None or ram is None:
        local_cpu, local_ram = _read_local_cpu_ram()
        cpu = local_cpu if cpu is None else cpu
        ram = local_ram if ram is None else ram
    return {
        "model": llm.get("model", "unknown"),
        "provider": str(llm.get("provider", "unknown")).capitalize(),
        "cpu": cpu,
        "ram": ram,
        "online": True,
        "error": "",
    }

def _clip(text: str, limit: int = OUTPUT_LIMIT) -> str:
    if len(text) <= limit:
        return text
    return text[:limit] + f"\n...[saida truncada em {limit} caracteres]"

def _preview_text(text: str, limit: int = 72) -> str:
    compact = " ".join(text.split())
    if len(compact) <= limit:
        return compact
    return compact[: limit - 1] + "…"

def _exit_after_cleanup(app: App | None = None, code: int = 0) -> None:
    if app is not None:
        try:
            app.exit()
        except Exception:
            pass
    timer = threading.Timer(0.25, lambda: os._exit(code))
    timer.daemon = True
    timer.start()

def _run_process(args: list[str], timeout: int = SHELL_TIMEOUT) -> tuple[int, str, str]:
    """Run a command without shell expansion and return returncode/stdout/stderr."""
    try:
        proc = subprocess.run(
            args,
            capture_output=True,
            text=True,
            timeout=timeout,
            cwd=str(ROOT_DIR),
        )
        return proc.returncode, _clip(proc.stdout), _clip(proc.stderr)
    except subprocess.TimeoutExpired:
        return -1, "", f"Timeout ({timeout}s)"
    except FileNotFoundError:
        return 127, "", f"Comando nao encontrado: {args[0]}"
    except Exception as e:
        return -1, "", str(e)

def _run_user_shell(cmd: str, timeout: int = SHELL_TIMEOUT) -> tuple[int, str, str]:
    """Run an explicit user shell command from !cmd."""
    shell = os.environ.get("SHELL") or "/bin/sh"
    return _run_process([shell, "-lc", cmd], timeout=timeout)

def _first_available(*names: str) -> str | None:
    for name in names:
        if shutil.which(name):
            return name
    return None

def _limit_lines(text: str, count: int) -> str:
    return "\n".join(text.splitlines()[:count])

def _system_summary() -> tuple[int, str, str]:
    lines = [
        f"Hostname: {gethostname()}",
        f"Kernel:   {platform.release()}",
        f"Arch:     {platform.machine()}",
        f"Python:   {platform.python_version()}",
        f"Backend:  {BACKEND}",
    ]
    uptime_path = Path("/proc/uptime")
    if uptime_path.exists():
        try:
            seconds = int(float(uptime_path.read_text().split()[0]))
            days, rem = divmod(seconds, 86400)
            hours, rem = divmod(rem, 3600)
            minutes, _ = divmod(rem, 60)
            lines.insert(2, f"Uptime:   {days}d {hours}h {minutes}m")
        except Exception:
            pass
    return 0, "\n".join(lines), ""

def _journal_lines(count: int) -> tuple[int, str, str]:
    count = max(1, min(count, 300))
    for args in (
        ["journalctl", "--user", "-u", "zeus", "-n", str(count), "--no-pager"],
        ["journalctl", "-u", "zeus", "-n", str(count), "--no-pager"],
    ):
        code, stdout, stderr = _run_process(args)
        if code == 0 and stdout.strip():
            return code, stdout, stderr
    return 1, "zeus.service nao encontrado no journal", ""

def _service_lines() -> tuple[int, str, str]:
    code, stdout, stderr = _run_process(["systemctl", "list-units", "--type=service", "--state=running", "--no-pager", "--no-legend"])
    return code, _limit_lines(stdout, 25), stderr

def _process_lines() -> tuple[int, str, str]:
    code, stdout, stderr = _run_process(["ps", "aux", "--sort=-%cpu"])
    return code, _limit_lines(stdout, 11), stderr

def _network_lines() -> tuple[int, str, str]:
    ip = _first_available("ip")
    if ip:
        return _run_process([ip, "-br", "addr", "show"])
    ifconfig = _first_available("ifconfig")
    if ifconfig:
        return _run_process([ifconfig])
    return 127, "", "Sem comando de rede disponivel: ip/ifconfig"

def _disk_lines() -> tuple[int, str, str]:
    return _run_process(["df", "-h"])

def _who_lines() -> tuple[int, str, str]:
    code, stdout, stderr = _run_process(["who"])
    code_w, stdout_w, stderr_w = _run_process(["w"])
    return max(code, code_w), "\n\n".join(part for part in [stdout, stdout_w] if part.strip()), "\n".join(part for part in [stderr, stderr_w] if part.strip())


SLASH_HELP = """
