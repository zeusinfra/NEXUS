#!/bin/bash
# ══════════════════════════════════════
#  NEXUS — Launcher Unificado
# ══════════════════════════════════════
DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$DIR")"
VENV="$ROOT_DIR/.venv/bin/python"
SYS="python3"

default_log_dir() {
    if [[ -n "${NEXUS_LOG_DIR:-}" ]]; then
        echo "$NEXUS_LOG_DIR"
    elif [[ "$ROOT_DIR" == "/usr/lib/nexus" ]]; then
        echo "${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/nexus/logs"
    else
        echo "$ROOT_DIR/logs"
    fi
}

default_runtime_dir() {
    if [[ -n "${NEXUS_RUNTIME_DIR:-}" ]]; then
        echo "$NEXUS_RUNTIME_DIR"
    elif [[ "$ROOT_DIR" == "/usr/lib/nexus" ]]; then
        echo "${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/nexus"
    else
        echo "$ROOT_DIR/runtime"
    fi
}

LOG_DIR="$(default_log_dir)"
RUNTIME_DIR="$(default_runtime_dir)"
SERVER_LOG="$LOG_DIR/nexus_server.log"

# Usa venv se existir, senão usa sistema
PY="$SYS"
[[ -f "$VENV" ]] && PY="$VENV"
mkdir -p "$LOG_DIR" "$RUNTIME_DIR"

WATCHER_PID=""
MEMORY_PID=""

service_responds() {
    curl -sS --max-time 0.7 "$1" >/dev/null 2>&1
}

backend_responds() {
    curl -sS --max-time 2 "http://127.0.0.1:${NEXUS_PORT:-8080}/api/health" >/dev/null 2>&1
}

backend_port_open() {
    timeout 1 bash -c "</dev/tcp/127.0.0.1/${NEXUS_PORT:-8080}" >/dev/null 2>&1
}

watcher_port() {
    echo "${NEXUS_WATCHER_PORT:-8081}"
}

watcher_responds() {
    timeout 1 bash -c "</dev/tcp/127.0.0.1/$(watcher_port)" >/dev/null 2>&1
}

watcher_port_open() {
    timeout 1 bash -c "</dev/tcp/127.0.0.1/$(watcher_port)" >/dev/null 2>&1
}

watcher_pids() {
    pgrep -f "watcher_rs" 2>/dev/null || true
}

stop_stale_watcher() {
    local pids
    pids="$(watcher_pids)"
    [[ -z "$pids" ]] && return 0
    echo "⚠️  Watcher Rust está presumidamente travado: $pids"
    kill $pids >/dev/null 2>&1 || true
    sleep 2
}

memory_service_url() {
    echo "${NEXUS_MEMORY_SERVICE_URL:-http://127.0.0.1:8085/health}"
}

memory_service_responds() {
    service_responds "$(memory_service_url)"
}

memory_service_port() {
    local url
    url="$(memory_service_url)"
    PYTHON_MEMORY_SERVICE_URL="$url" "$PY" - <<'PY'
import os, urllib.parse
url = os.environ['PYTHON_MEMORY_SERVICE_URL']
parsed = urllib.parse.urlparse(url)
port = parsed.port or (443 if parsed.scheme == 'https' else 80)
print(port)
PY
}

memory_service_pids() {
    pgrep -f "memory_service" 2>/dev/null || true
}

stop_stale_memory_service() {
    local pids
    pids="$(memory_service_pids)"
    [[ -z "$pids" ]] && return 0
    echo "⚠️  Memory service presumidamente travado: $pids"
    kill $pids >/dev/null 2>&1 || true
    sleep 2
}

backend_pids() {
    pgrep -f "python(3)? -m apps.web_gui|/python -m apps.web_gui|/python3 -m apps.web_gui" 2>/dev/null || true
}

stop_stale_backend() {
    local pids
    pids="$(backend_pids)"
    [[ -z "$pids" ]] && return 0
    echo "⚠️  Backend existe, mas não responde. Encerrando processo travado: $pids"
    kill $pids >/dev/null 2>&1 || true
    sleep 2
}

ensure_server_background() {
    if backend_responds; then
        echo "✅ Backend NEXUS já está respondendo."
        return 0
    fi

    if backend_port_open; then
        echo "⏳ Porta ${NEXUS_PORT:-8080} já está aberta. Aguardando health check..."
        for _ in $(seq 1 20); do
            if backend_responds; then
                echo "✅ Backend NEXUS pronto em http://127.0.0.1:${NEXUS_PORT:-8080}"
                return 0
            fi
            sleep 1
        done
        echo "❌ Porta ${NEXUS_PORT:-8080} está ocupada, mas /api/health não respondeu." >&2
        return 1
    fi

    stop_stale_backend
    if backend_responds; then
        echo "✅ Backend NEXUS voltou a responder."
        return 0
    fi

    if backend_port_open; then
        echo "❌ Porta ${NEXUS_PORT:-8080} ficou ocupada antes do start. Abortando para evitar duplicidade." >&2
        return 1
    fi

    echo "🌑 Iniciando backend NEXUS em background..."
    (
        cd "$ROOT_DIR"
        setsid -f nohup "$DIR/nexus" server > "$SERVER_LOG" 2>&1
    )

    for _ in $(seq 1 30); do
        if backend_responds; then
            sleep 1
            if ! backend_responds; then
                continue
            fi
            echo "✅ Backend NEXUS pronto em http://127.0.0.1:${NEXUS_PORT:-8080}"
            return 0
        fi
        sleep 1
    done

    echo "❌ Backend não respondeu dentro do tempo esperado. Veja $SERVER_LOG." >&2
    return 1
}

wait_for_port() {
    local host=$1
    local port=$2
    local retries=${3:-10}
    local i=0
    while [[ $i -lt $retries ]]; do
        if timeout 1 bash -c "</dev/tcp/${host}/${port}" >/dev/null 2>&1; then
            return 0
        fi
        i=$((i + 1))
        sleep 1
    done
    return 1
}

run_iced_gui() {
    if [[ -x "$DIR/nexus-iced" ]]; then
        exec "$DIR/nexus-iced"
    fi

    if [[ -d "$ROOT_DIR/nexus-iced" ]]; then
        if ! command -v cargo >/dev/null 2>&1; then
            echo "❌ Cargo não está disponível para iniciar a GUI em modo desenvolvimento." >&2
            return 1
        fi
        (cd "$ROOT_DIR/nexus-iced" && cargo run --release)
        return $?
    fi

    echo "❌ GUI Iced não encontrada. Reinstale o pacote ou rode 'make deb' para gerar binários." >&2
    return 1
}

start_watcher_process() {
    if [[ -x "$DIR/watcher_rs" ]]; then
        (
            cd "$ROOT_DIR" && setsid -f nohup "$DIR/watcher_rs" > "$LOG_DIR/watcher.log" 2>&1
        ) &
        WATCHER_PID=$!
        return 0
    fi

    if [[ -d "$ROOT_DIR/watcher_rs" ]]; then
        if ! command -v cargo >/dev/null 2>&1; then
            echo "❌ Cargo não está disponível para iniciar o Watcher em modo desenvolvimento." >&2
            return 1
        fi
        (
            cd "$ROOT_DIR/watcher_rs" && setsid -f nohup cargo run --release > "$LOG_DIR/watcher.log" 2>&1
        ) &
        WATCHER_PID=$!
        return 0
    fi

    echo "❌ Watcher Rust não encontrado no runtime instalado." >&2
    return 1
}

start_memory_service_process() {
    if [[ -x "$DIR/memory_service" ]]; then
        (
            cd "$RUNTIME_DIR" && setsid -f nohup "$DIR/memory_service" > "$LOG_DIR/memory.log" 2>&1
        ) &
        MEMORY_PID=$!
        return 0
    fi

    if [[ -d "$ROOT_DIR/core-rust/nexus_memory" ]]; then
        if ! command -v cargo >/dev/null 2>&1; then
            echo "❌ Cargo não está disponível para iniciar o Memory Service em modo desenvolvimento." >&2
            return 1
        fi
        (
            cd "$ROOT_DIR/core-rust/nexus_memory" && setsid -f nohup cargo run --release --bin memory_service > "$LOG_DIR/memory.log" 2>&1
        ) &
        MEMORY_PID=$!
        return 0
    fi

    echo "❌ Memory Service Rust não encontrado no runtime instalado." >&2
    return 1
}

ensure_watcher_background() {
    local port
    port="$(watcher_port)"
    if watcher_responds; then
        echo "✅ Watcher Rust já está respondendo na porta ${port}."
        return 0
    fi

    if watcher_port_open; then
        echo "⏳ Porta ${port} aberta, aguardando Watcher responder..."
        if wait_for_port 127.0.0.1 "$port" 15; then
            echo "✅ Watcher Rust pronto em ws://127.0.0.1:${port}/ws"
            return 0
        fi
        echo "⚠️  Porta ${port} está aberta, mas Watcher não responde. Reiniciando processo." >&2
        stop_stale_watcher
    fi

    echo "🌑 Iniciando Watcher Rust..."
    start_watcher_process

    if wait_for_port 127.0.0.1 "$port" 20; then
        echo "✅ Watcher Rust pronto em ws://127.0.0.1:${port}/ws"
        return 0
    fi

    echo "❌ Watcher Rust não respondeu dentro do tempo esperado. Veja $LOG_DIR/watcher.log." >&2
    return 1
}

ensure_memory_service_background() {
    local url port
    url="$(memory_service_url)"
    port="$(memory_service_port)"

    if memory_service_responds; then
        echo "✅ Memory Service já está respondendo em ${url}."
        return 0
    fi

    if timeout 1 bash -c "</dev/tcp/127.0.0.1/${port}" >/dev/null 2>&1; then
        echo "⏳ Porta ${port} ativa, aguardando /health do memory_service..."
        for _ in $(seq 1 15); do
            if memory_service_responds; then
                echo "✅ Memory Service pronto em ${url}"
                return 0
            fi
            sleep 1
        done
        echo "⚠️  Porta ${port} está ocupada, mas /health não respondeu. Reiniciando serviço de memória." >&2
        stop_stale_memory_service
    fi

    echo "🌑 Iniciando Memory Service Rust..."
    start_memory_service_process

    for _ in $(seq 1 20); do
        if memory_service_responds; then
            echo "✅ Memory Service pronto em ${url}"
            return 0
        fi
        sleep 1
    done

    echo "❌ Memory Service não respondeu dentro do tempo esperado. Veja $LOG_DIR/memory.log." >&2
    return 1
}

start_rust_services() {
    echo "🦀 Iniciando Microsserviços Rust (Watcher & Memory)..."
    ensure_watcher_background
    ensure_memory_service_background
}

cleanup_started_services() {
    [[ -n "$WATCHER_PID" ]] && kill "$WATCHER_PID" >/dev/null 2>&1 || true
    [[ -n "$MEMORY_PID" ]] && kill "$MEMORY_PID" >/dev/null 2>&1 || true
}

export_headless_light_profile() {
    export NEXUS_ENABLE_VOICE_SENSING="${NEXUS_ENABLE_VOICE_SENSING:-0}"
    export NEXUS_ENABLE_BROWSER_SENSING="${NEXUS_ENABLE_BROWSER_SENSING:-0}"
    export NEXUS_ENABLE_INTERNAL_WATCHER="${NEXUS_ENABLE_INTERNAL_WATCHER:-0}"
    export NEXUS_ENABLE_AUTONOMOUS_TASKS="${NEXUS_ENABLE_AUTONOMOUS_TASKS:-0}"
    export NEXUS_ENABLE_BOOT_GREETING="${NEXUS_ENABLE_BOOT_GREETING:-0}"
    export NEXUS_ENABLE_RESOURCE_MONITOR="${NEXUS_ENABLE_RESOURCE_MONITOR:-0}"
    export NEXUS_LOW_MEM_AUTO="${NEXUS_LOW_MEM_AUTO:-1}"
}

trap cleanup_started_services EXIT INT TERM

# Força UTF-8
export PYTHONIOENCODING=utf-8
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

# Suprime mensagens de debug ALSA/JACK (sem quebrar o PortAudio)
export ALSA_CARD=0
export SDL_AUDIODRIVER=pulseaudio

# Help rápido: ./nexus help
if [[ "$1" == "help" || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "╔════════════════════════════════════╗"
    echo "║     NEXUS — Command Launcher       ║"
    echo "╚════════════════════════════════════╝"
    echo ""
    echo "  ./bin/nexus               → Rust Iced GUI (padrão)"
    echo "  ./bin/nexus iced           → Abrir GUI Rust Iced (explícito)"
    echo "  ./bin/nexus server         → Backend headless"
    echo "  ./bin/nexus ensure-server  → Garantir backend online"
    echo "  ./bin/nexus status         → Status Linux/produto, modelos e daemon"
    echo "  ./bin/nexus health         → Verificações de saúde do produto"
    echo "  ./bin/nexus model status   → Status LLM cloud/local"
    echo "  ./bin/nexus model list-local → Modelos Ollama detectados"
    echo "  ./bin/nexus router explain \"tarefa\" → Explicar roteamento híbrido"
    echo "  ./bin/nexus org status     → Estado da empresa cognitiva"
    echo "  ./bin/nexus org health     → Health do daemon organizacional"
    echo "  ./bin/nexus org run        → Daemon organizacional"
    echo "  ./bin/nexus org systemd-plan → Plano de instalação systemd"
    echo "  ./bin/nexus org memory-status → Memória organizacional"
    echo "  ./bin/nexus tui            → TUI operacional Bubble Tea"
    echo "  ./bin/nexus logs           → Ver logs em tempo real"
    echo "  ./bin/nexus v4             → Core v4 (loop contínuo)"
    echo "  ./bin/nexus evolve         → Motor de Evolução"
    echo "  ./bin/nexus restart        → Reiniciar Sistema (Backend + Rust)"
    echo "  ./bin/nexus setup-aliases  → Instalar aliases"
    echo ""
    exit 0
fi

case "$1" in
    gui|iced|"")
        echo "🧠 NEXUS — Iniciando GUI Iced..."
        ensure_server_background
        run_iced_gui
        ;;
    v4|core4|daemon)
        echo "🧠 Iniciando NEXUS Cognitive Core v4 (Loop contínuo)..."
        echo "📝 Inbox: scratch/v4_inbox.txt (adicione texto lá para o core perceber)"
        "$PY" -m apps.nexus_v4
        ;;
    server|headless)
        echo "🌑 Iniciando NEXUS em modo Headless (Cérebro em Background)..."
        export_headless_light_profile
        if backend_responds; then
            echo "✅ Backend NEXUS já está respondendo em http://127.0.0.1:${NEXUS_PORT:-8080}"
            exit 0
        fi
        if backend_port_open; then
            echo "❌ Porta ${NEXUS_PORT:-8080} já está ocupada, mas /api/health não respondeu. Use './bin/nexus ensure-server' para diagnosticar." >&2
            exit 1
        fi
        stop_stale_backend
        start_rust_services
        echo "🧠 NEXUS Core operacional. Conecte-se via Applet/HUD."
        "$PY" -m apps.web_gui --headless
        ;;
    ensure-server)
        ensure_server_background
        ;;
    setup|status|health|doctor|model|router|ask|run|config|agents|uninstall)
        "$PY" -m nexus_core.product_cli "$@"
        ;;
    org|organization)
        shift
        "$PY" -m nexus_core.organization "${@:-status}"
        ;;
    tui)
        if ! command -v go >/dev/null 2>&1; then
            echo "❌ Go não está instalado. A TUI Bubble Tea precisa do toolchain Go." >&2
            exit 1
        fi
        (cd "$ROOT_DIR/interfaces/tui-bubbletea" && go run .)
        ;;
    evolve|think|ev)
        echo "🌀 Iniciando Motor de Evolução..."
        "$PY" -m apps.nexus_evolution
        ;;
    logs)
        shift
        "$PY" -m nexus_core.product_cli logs "$@"
        ;;
    restart)
        echo "🔄 Reiniciando NEXUS (Ciclo Neural Completo)..."
        pids="$(backend_pids)"
        if [[ -n "$pids" ]]; then
            echo "🛑 Parando backend ($pids)..."
            kill $pids >/dev/null 2>&1 || true
            sleep 2
        fi
        pkill -f "nexus_memory" || true
        pkill -f "watcher_rs" || true
        ensure_server_background
        echo "✅ Reinicialização concluída."
        ;;
    setup-aliases)
        grep -q "alias nexus=" ~/.bashrc || echo "alias nexus='cd $ROOT_DIR && ./bin/nexus'" >> ~/.bashrc
        grep -q "alias nexus-server" ~/.bashrc || echo "alias nexus-server='cd $ROOT_DIR && ./bin/nexus server'" >> ~/.bashrc
        echo "✅  Aliases criados: 'nexus' e 'nexus-server'."
        echo "🔄  Execute 'source ~/.bashrc' para ativar."
        ;;
    *)
        echo "❌ Comando desconhecido: ${1:-<vazio>}" >&2
        echo "Use './bin/nexus help' para listar comandos." >&2
        exit 2
        ;;
esac
