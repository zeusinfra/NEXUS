#!/bin/bash
# ══════════════════════════════════════
#  ZEUS — Launcher Unificado
# ══════════════════════════════════════
DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$DIR")"
VENV="$ROOT_DIR/.venv/bin/python"
SYS="python3"

# Usa venv se existir, senão usa sistema
PY="$SYS"
[[ -f "$VENV" ]] && PY="$VENV"
mkdir -p "$ROOT_DIR/logs"

WATCHER_PID=""
MEMORY_PID=""

service_responds() {
    curl -sS --max-time 0.7 "$1" >/dev/null 2>&1
}

backend_responds() {
    curl -sS --max-time 2 "http://127.0.0.1:${ZEUS_PORT:-8080}/api/health" >/dev/null 2>&1
}

backend_port_open() {
    timeout 1 bash -c "</dev/tcp/127.0.0.1/${ZEUS_PORT:-8080}" >/dev/null 2>&1
}

backend_pids() {
    pgrep -f "python(3)? -m apps.web_gui|/python -m apps.web_gui|/python3 -m apps.web_gui" 2>/dev/null || true
}

stop_stale_backend() {
    local pids
    pids="$(backend_pids)"
    [[ -z "$pids" ]] && return 0
    echo "⚠️  Backend existe, mas não responde. Encerrando processo travado: $pids"
    kill $pids >/dev/null 2>&1 || true
    sleep 2
}

ensure_server_background() {
    if backend_responds; then
        echo "✅ Backend ZEUS já está respondendo."
        return 0
    fi

    if backend_port_open; then
        echo "⏳ Porta ${ZEUS_PORT:-8080} já está aberta. Aguardando health check..."
        for _ in $(seq 1 20); do
            if backend_responds; then
                echo "✅ Backend ZEUS pronto em http://127.0.0.1:${ZEUS_PORT:-8080}"
                return 0
            fi
            sleep 1
        done
        echo "❌ Porta ${ZEUS_PORT:-8080} está ocupada, mas /api/health não respondeu." >&2
        return 1
    fi

    stop_stale_backend
    if backend_responds; then
        echo "✅ Backend ZEUS voltou a responder."
        return 0
    fi

    if backend_port_open; then
        echo "❌ Porta ${ZEUS_PORT:-8080} ficou ocupada antes do start. Abortando para evitar duplicidade." >&2
        return 1
    fi

    echo "🌑 Iniciando backend ZEUS em background..."
    (
        cd "$ROOT_DIR"
        setsid -f nohup "$DIR/zeus" server > "$ROOT_DIR/zeus_server.log" 2>&1
    )

    for _ in $(seq 1 30); do
        if backend_responds; then
            sleep 1
            if ! backend_responds; then
                continue
            fi
            echo "✅ Backend ZEUS pronto em http://127.0.0.1:${ZEUS_PORT:-8080}"
            return 0
        fi
        sleep 1
    done

    echo "❌ Backend não respondeu dentro do tempo esperado. Veja zeus_server.log." >&2
    return 1
}

start_rust_services() {
    echo "🦀 Iniciando Microsserviços Rust (Watcher & Memory)..."
    if service_responds "http://127.0.0.1:8081/ws"; then
        echo "✅ Watcher Rust já está respondendo na porta 8081."
    else
        (cd "$ROOT_DIR/watcher_rs" && cargo run --release > "$ROOT_DIR/logs/watcher.log" 2>&1) &
        WATCHER_PID=$!
    fi

    if service_responds "http://127.0.0.1:8082/health"; then
        echo "✅ Memory Service já está respondendo na porta 8082."
    else
        (cd "$ROOT_DIR/core-rust/zeus_memory" && cargo run --release --bin memory_service > "$ROOT_DIR/logs/memory.log" 2>&1) &
        MEMORY_PID=$!
    fi
    sleep 2
}

cleanup_started_services() {
    [[ -n "$WATCHER_PID" ]] && kill "$WATCHER_PID" >/dev/null 2>&1 || true
    [[ -n "$MEMORY_PID" ]] && kill "$MEMORY_PID" >/dev/null 2>&1 || true
}

export_headless_light_profile() {
    export ZEUS_ENABLE_VOICE_SENSING="${ZEUS_ENABLE_VOICE_SENSING:-0}"
    export ZEUS_ENABLE_BROWSER_SENSING="${ZEUS_ENABLE_BROWSER_SENSING:-0}"
    export ZEUS_ENABLE_INTERNAL_WATCHER="${ZEUS_ENABLE_INTERNAL_WATCHER:-0}"
    export ZEUS_ENABLE_AUTONOMOUS_TASKS="${ZEUS_ENABLE_AUTONOMOUS_TASKS:-0}"
    export ZEUS_ENABLE_BOOT_GREETING="${ZEUS_ENABLE_BOOT_GREETING:-0}"
    export ZEUS_ENABLE_RESOURCE_MONITOR="${ZEUS_ENABLE_RESOURCE_MONITOR:-0}"
    export ZEUS_LOW_MEM_AUTO="${ZEUS_LOW_MEM_AUTO:-1}"
}

trap cleanup_started_services EXIT INT TERM

# Força UTF-8
export PYTHONIOENCODING=utf-8
export LC_ALL=C.UTF-8
export LANG=C.UTF-8

# Suprime mensagens de debug ALSA/JACK (sem quebrar o PortAudio)
export ALSA_CARD=0
export SDL_AUDIODRIVER=pulseaudio

# Help rápido: ./zeus help
if [[ "$1" == "help" || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "╔════════════════════════════════════╗"
    echo "║     ZEUS — Command Launcher        ║"
    echo "╚════════════════════════════════════╝"
    echo ""
    echo "  ./zeus               → Cyber TUI (padrão)"
    echo "  ./zeus tui            → Cyber TUI (explícito)"
    echo "  ./zeus chat           → Abrir chat GTK (desktop)"
    echo "  ./zeus web            → Iniciar Servidor (Browser)"
    echo "  ./zeus server         → Backend headless"
    echo "  ./zeus ensure-server  → Garantir backend online"
    echo "  ./zeus logs           → Ver logs em tempo real"
    echo "  ./zeus v4             → Core v4 (loop contínuo)"
    echo "  ./zeus evolve         → Motor de Evolução"
    echo "  ./zeus setup-aliases  → Instalar aliases"
    echo ""
    exit 0
fi

case "$1" in
    sphere|gui|3d|web)
        echo "🧠 Iniciando ZEUS Command Center (Browser)..."
        echo "🌐 Acesse: http://127.0.0.1:8080"
        start_rust_services
        "$PY" -m apps.web_gui
        ;;
    v4|core4|daemon)
        echo "🧠 Iniciando ZEUS Cognitive Core v4 (Loop contínuo)..."
        echo "📝 Inbox: scratch/v4_inbox.txt (adicione texto lá para o core perceber)"
        "$PY" -m apps.zeus_v4
        ;;
    server|headless)
        echo "🌑 Iniciando ZEUS em modo Headless (Cérebro em Background)..."
        export_headless_light_profile
        if backend_responds; then
            echo "✅ Backend ZEUS já está respondendo em http://127.0.0.1:${ZEUS_PORT:-8080}"
            exit 0
        fi
        if backend_port_open; then
            echo "❌ Porta ${ZEUS_PORT:-8080} já está ocupada, mas /api/health não respondeu. Use './bin/zeus ensure-server' para diagnosticar." >&2
            exit 1
        fi
        stop_stale_backend
        start_rust_services
        echo "🧠 ZEUS Core operacional. Conecte-se via Applet/HUD."
        "$PY" -m apps.web_gui --headless
        ;;
    ensure-server)
        ensure_server_background
        ;;
    evolve|think|ev)
        echo "🌀 Iniciando Motor de Evolução..."
        "$PY" -m apps.zeus_evolution
        ;;
    logs)
        echo "📜  Monitorando logs do ZEUS..."
        tail -f zeus_server.log
        ;;
    tui|console|ops)
        echo "📟  Iniciando ZEUS Cyber TUI..."
        ensure_server_background
        "$PY" "$ROOT_DIR/bin/zeus-cyber-tui"
        ;;
    chat)
        echo "💬  Abrindo chat ZEUS GTK..."
        "$ROOT_DIR/bin/zeus-chat"
        ;;
    setup-aliases)
        echo "🔧  Configurando aliases globais em ~/.bashrc..."
        grep -q "alias zeus-server" ~/.bashrc || echo "alias zeus-server='cd $ROOT_DIR && ./bin/zeus web > zeus_server.log 2>&1 & sleep 1 && tail -f zeus_server.log'" >> ~/.bashrc
        grep -q "alias zeus-chat" ~/.bashrc || echo "alias zeus-chat='cd $ROOT_DIR && ./bin/zeus-chat'" >> ~/.bashrc
        echo "✅  Aliases criados: 'zeus-server' e 'zeus-chat'."
        echo "🔄  Execute 'source ~/.bashrc' para ativar."
        ;;
    *)
        # Padrão: inicia o Cyber TUI com backend
        echo "🧠 ZEUS — Iniciando..."
        ensure_server_background
        "$PY" "$ROOT_DIR/bin/zeus-cyber-tui"
        ;;
esac
