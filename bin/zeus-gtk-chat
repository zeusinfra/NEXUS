#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import base64
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request
import webbrowser
from datetime import datetime

ROOT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
if ROOT_DIR not in sys.path:
    sys.path.insert(0, ROOT_DIR)

from zeus_core.response_text import pango_markup, speech_text

import gi
gi.require_version("Gdk", "4.0")
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gdk, Gio, GLib, Gtk, Pango, Adw

# Inicializar Libadwaita
Adw.init()

# Se o primeiro argumento não começar com '--', assumimos que é a URL do backend.
_backend_arg = sys.argv[1] if len(sys.argv) > 1 and not sys.argv[1].startswith("--") else None
BACKEND = (_backend_arg or os.getenv("ZEUS_BACKEND_URL", "http://127.0.0.1:8080")).rstrip("/")
APP_ID = "local.zeus.CognitiveChat"


class ZeusGtkChat(Adw.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE)
        self.window: Adw.ApplicationWindow | None = None
        self.toast_overlay: Adw.ToastOverlay | None = None
        self.messages_box: Gtk.Box | None = None
        self.scroller: Gtk.ScrolledWindow | None = None
        self.input: Gtk.Entry | None = None
        self.send_button: Gtk.Button | None = None
        self.cancel_button: Gtk.Button | None = None
        self.spinner: Gtk.Spinner | None = None
        self.window_title: Adw.WindowTitle | None = None
        self.status_page: Adw.StatusPage | None = None
        self.banner: Adw.Banner | None = None
        
        self._last_status: dict = {}
        self._voice_enabled = True
        self._cancel_requested = False
        self._is_generating = False
        self._autostart_mode = False

    def do_command_line(self, command_line) -> int:
        args = command_line.get_arguments()
        self._autostart_mode = "--autostart" in args
        self.activate()
        return 0

    def do_activate(self) -> None:
        if self.window is None:
            self.window = self._build_window()
            self._apply_theme()
            self._check_status()
            
            # Live telemetry polling every 2 seconds
            GLib.timeout_add(2000, self._poll_status)
            
            if self._autostart_mode:
                GLib.timeout_add(1500, self._trigger_autostart_greeting)
            
            # Contextual Placeholder Timer
            GLib.timeout_add_seconds(15, self._update_contextual_placeholder)
                
        self.window.present()

    def _apply_theme(self) -> None:
        style_manager = Adw.StyleManager.get_default()
        theme = os.getenv("ZEUS_GTK_THEME", "dark").lower()
        if theme == "dark":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_DARK)
        elif theme == "light":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_LIGHT)
        else:
            style_manager.set_color_scheme(Adw.ColorScheme.DEFAULT)

    def _build_window(self) -> Adw.ApplicationWindow:
        self._install_css()

        window = Adw.ApplicationWindow(application=self)
        window.set_default_size(1100, 760)
        window.add_css_class("zeus-window")
        
        # Keyboard shortcuts
        key_ctrl = Gtk.EventControllerKey.new()
        key_ctrl.connect("key-pressed", self._on_key_press)
        window.add_controller(key_ctrl)

        # Main overlay for Toasts
        self.toast_overlay = Adw.ToastOverlay()
        window.set_content(self.toast_overlay)

        # Main vertical box
        self.main_container = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.toast_overlay.set_child(self.main_container)

        # SIDEBAR (Telemetria Premium)
        sidebar_scroll = Gtk.ScrolledWindow()
        sidebar_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        sidebar_scroll.set_size_request(240, -1)
        sidebar_scroll.add_css_class("sidebar-scroll")

        self.sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
