#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import base64
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.request
import webbrowser
from datetime import datetime

ROOT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
if ROOT_DIR not in sys.path:
    sys.path.insert(0, ROOT_DIR)

from zeus_core.response_text import pango_markup, speech_text

import gi
gi.require_version("Gdk", "4.0")
gi.require_version("Gtk", "4.0")
gi.require_version("Adw", "1")
from gi.repository import Gdk, Gio, GLib, Gtk, Pango, Adw

# Inicializar Libadwaita
Adw.init()

BACKEND = (sys.argv[1] if len(sys.argv) > 1 else os.getenv("ZEUS_BACKEND_URL", "http://127.0.0.1:8080")).rstrip("/")
APP_ID = "local.zeus.CognitiveChat"


class ZeusGtkChat(Adw.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE)
        self.window: Adw.ApplicationWindow | None = None
        self.toast_overlay: Adw.ToastOverlay | None = None
        self.messages_box: Gtk.Box | None = None
        self.scroller: Gtk.ScrolledWindow | None = None
        self.input: Gtk.Entry | None = None
        self.send_button: Gtk.Button | None = None
        self.cancel_button: Gtk.Button | None = None
        self.spinner: Gtk.Spinner | None = None
        self.window_title: Adw.WindowTitle | None = None
        self.status_page: Adw.StatusPage | None = None
        self.banner: Adw.Banner | None = None
        
        self._last_status: dict = {}
        self._voice_enabled = True
        self._cancel_requested = False
        self._is_generating = False

    def do_activate(self) -> None:
        if self.window is None:
            self.window = self._build_window()
            self._apply_theme()
            self._check_status()
        self.window.present()

    def do_command_line(self, command_line) -> int:
        self.activate()
        return 0

    def _apply_theme(self) -> None:
        style_manager = Adw.StyleManager.get_default()
        theme = os.getenv("ZEUS_GTK_THEME", "dark").lower()
        if theme == "dark":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_DARK)
        elif theme == "light":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_LIGHT)
        else:
            style_manager.set_color_scheme(Adw.ColorScheme.DEFAULT)

    def _build_window(self) -> Adw.ApplicationWindow:
        self._install_css()

        window = Adw.ApplicationWindow(application=self)
        window.set_default_size(580, 780)
        window.add_css_class("zeus-window")
        
        # Keyboard shortcuts
        key_ctrl = Gtk.EventControllerKey.new()
        key_ctrl.connect("key-pressed", self._on_key_press)
        window.add_controller(key_ctrl)

        # Main overlay for Toasts
        self.toast_overlay = Adw.ToastOverlay()
        window.set_content(self.toast_overlay)

        # Main vertical box
        main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.toast_overlay.set_child(main_box)

        # HeaderBar
        header = Adw.HeaderBar()
        main_box.append(header)

        self.window_title = Adw.WindowTitle(title="ZEUS Ops", subtitle="Inicializando...")
        header.set_title_widget(self.window_title)

        # Voice Toggle
        self.voice_button = Gtk.ToggleButton()
        self.voice_button.set_icon_name("audio-volume-high-symbolic")
        self.voice_button.set_active(True)
        self.voice_button.set_tooltip_text("Alternar Voz")
        self.voice_button.connect("toggled", self._toggle_voice)
        header.pack_end(self.voice_button)

        # HUD Button
        hud_button = Gtk.Button(icon_name="applications-internet-symbolic")
        hud_button.set_tooltip_text("Abrir HUD Web")
        hud_button.connect("clicked", lambda _: webbrowser.open(BACKEND))
        header.pack_end(hud_button)

        # Diagnostic Button
        diag_button = Gtk.Button(icon_name="dialog-information-symbolic")
        diag_button.set_tooltip_text("Diagnóstico do ZEUS")
        diag_button.connect("clicked", self._show_diagnostic)
        header.pack_start(diag_button)

        # Banner for Offline status
        self.banner = Adw.Banner()
        self.banner.set_title("Backend ZEUS offline. Verifique se o serviço está ativo.")
        self.banner.set_button_label("Tentar novamente")
        self.banner.connect("button-clicked", lambda _: self._check_status())
        main_box.append(self.banner)

        # Scroller
        self.scroller = Gtk.ScrolledWindow()
        self.scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.scroller.set_vexpand(True)
        self.scroller.add_css_class("chat-scroll")
        
        # Clamp for centered reading
        clamp = Adw.Clamp()
        clamp.set_maximum_size(860)
        clamp.set_tightening_threshold(600)
        
        self.scroller.set_child(clamp)
        main_box.append(self.scroller)

        # Box for messages
        self.messages_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.messages_box.set_margin_top(24)
        self.messages_box.set_margin_bottom(24)
        self.messages_box.set_margin_start(16)
        self.messages_box.set_margin_end(16)
        
        # Empty State
        self.status_page = Adw.StatusPage()
        self.status_page.set_icon_name("system-run-symbolic")
        self.status_page.set_title("ZEUS pronto")
        self.status_page.set_description("Digite uma mensagem para iniciar.")
        self.status_page.add_css_class("empty-state")
        
        overlay_box = Gtk.Overlay()
        overlay_box.set_child(self.messages_box)
        overlay_box.add_overlay(self.status_page)
        clamp.set_child(overlay_box)

        # Composer area
        composer_clamp = Adw.Clamp()
        composer_clamp.set_maximum_size(860)
        composer_clamp.set_tightening_threshold(600)

        composer_bg = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        composer_bg.add_css_class("composer-bg")
        composer_bg.append(composer_clamp)
        main_box.append(composer_bg)

        composer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        composer.add_css_class("composer")
        composer.set_margin_start(16)
        composer.set_margin_end(16)
        composer.set_margin_top(16)
        composer.set_margin_bottom(24)
        composer_clamp.set_child(composer)

        self.input = Gtk.Entry()
        self.input.set_placeholder_text("Peça uma ação, diagnóstico ou sincronização...")
        self.input.connect("activate", self._send_message)
        self.input.set_hexpand(True)
        composer.append(self.input)

        self.spinner = Gtk.Spinner()
        composer.append(self.spinner)

        self.cancel_button = Gtk.Button(icon_name="media-playback-stop-symbolic")
        self.cancel_button.set_tooltip_text("Cancelar geração (Esc)")
        self.cancel_button.add_css_class("destructive-action")
        self.cancel_button.set_visible(False)
        self.cancel_button.connect("clicked", self._cancel_generation)
        composer.append(self.cancel_button)

        self.send_button = Gtk.Button(icon_name="mail-send-symbolic")
        self.send_button.add_css_class("suggested-action")
        self.send_button.set_tooltip_text("Enviar mensagem (Enter)")
        self.send_button.connect("clicked", self._send_message)
        composer.append(self.send_button)

        print("[GTK] App started")
        return window

    def _install_css(self) -> None:
        css = """
        .zeus-window { background-color: @window_bg_color; }
        .composer-bg { background-color: @window_bg_color; border-top: 1px solid @borders; }
        .empty-state { opacity: 0.7; }
        .message-row { margin-bottom: 8px; }
        .message-bubble { border-radius: 16px; padding: 12px 16px; line-height: 1.4; }
        .message-bubble-user { background-color: @accent_bg_color; color: @accent_fg_color; border-bottom-right-radius: 4px; }
        .message-bubble-assistant { background-color: @card_bg_color; border: 1px solid @borders; border-bottom-left-radius: 4px; }
        .message-bubble-system { background-color: transparent; opacity: 0.7; font-size: 0.9em; }
        .message-meta { opacity: 0.65; font-size: 0.75em; margin-top: 4px; }
        .message-meta-user { color: @accent_fg_color; }
        .code-card { background-color: @dark_2; border: 1px solid @borders; border-radius: 12px; margin-top: 8px; margin-bottom: 8px; }
        .code-header { background-color: @dark_3; padding: 6px 12px; border-bottom: 1px solid @borders; font-size: 0.85em; opacity: 0.9; }
        .code-content { padding: 12px; font-family: monospace; font-size: 0.95em; }
        """
        provider = Gtk.CssProvider()
        provider.load_from_string(css)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def _toast(self, message: str, timeout: int = 3) -> None:
        if self.toast_overlay:
            toast = Adw.Toast.new(message)
            toast.set_timeout(timeout)
            self.toast_overlay.add_toast(toast)
        else:
            print(f"[GTK][Toast fallback] {message}")

    def _set_status(self, subtitle: str) -> None:
        if self.window_title:
            self.window_title.set_subtitle(subtitle)

    def _show_diagnostic(self, *_args) -> None:
        provider = self._last_status.get("llm", {}).get("provider", "desconhecido")
        is_online = bool(self._last_status) and not self.banner.get_revealed()
        msg = f"Backend: {'Online' if is_online else 'Offline'}\\nModo: leve\\nLLM: {provider}"
        self._toast(msg, timeout=4)

    def _on_key_press(self, controller, keyval, keycode, state) -> bool:
        if keyval in (Gdk.KEY_l, Gdk.KEY_L) and (state & Gdk.ModifierType.CONTROL_MASK):
            self._clear_messages()
            return True
        if keyval == Gdk.KEY_Escape and self._is_generating:
            self._cancel_generation()
            return True
        return False

    def _clear_messages(self) -> None:
        if self.messages_box is not None:
            while self.messages_box.get_first_child() is not None:
                self.messages_box.remove(self.messages_box.get_first_child())
            self.status_page.set_visible(True)
            self._add_message("system", "Chat limpo localmente.")

    def _toggle_voice(self, button: Gtk.ToggleButton) -> None:
        self._voice_enabled = button.get_active()
        self._toast(f"Voz {'ativada' if self._voice_enabled else 'desativada'}")

    def _copy_to_clipboard(self, text: str, label: str = "Copiado") -> None:
        clipboard = Gdk.Display.get_default().get_clipboard()
        clipboard.set(text)
        self._toast(label)

    def _add_message(self, role: str, content: str) -> None:
        if self.status_page and self.status_page.get_visible():
            self.status_page.set_visible(False)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.add_css_class("message-row")
        
        timestamp = datetime.now().strftime("%H:%M")

        if role == "user":
            row.set_halign(Gtk.Align.END)
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-user")
            
            label = Gtk.Label(label=content)
            label.set_wrap(True)
            label.set_selectable(True)
            label.set_halign(Gtk.Align.START)
            content_box.append(label)
            
            meta = Gtk.Label(label=timestamp)
            meta.add_css_class("message-meta")
            meta.add_css_class("message-meta-user")
            meta.set_halign(Gtk.Align.END)
            content_box.append(meta)
            
            bubble_box.append(content_box)
            
            avatar = Adw.Avatar(text="U", size=36, show_initials=True)
            
            row.append(bubble_box)
            row.append(avatar)
            
        elif role == "assistant":
            row.set_halign(Gtk.Align.START)
            
            avatar = Adw.Avatar(text="Z", size=36, show_initials=True)
            
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            bubble_box.set_hexpand(True)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-assistant")
            
            rendered_content = self._render_message_content(content)
            content_box.append(rendered_content)
            
            actions_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            actions_box.set_margin_top(6)
            
            meta = Gtk.Label(label=f"ZEUS · {timestamp}")
            meta.add_css_class("message-meta")
            actions_box.append(meta)
            
            copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
            copy_btn.add_css_class("flat")
            copy_btn.add_css_class("circular")
            copy_btn.set_tooltip_text("Copiar mensagem")
            copy_btn.connect("clicked", lambda _, txt=content: self._copy_to_clipboard(txt, "Mensagem copiada"))
            
            spacer = Gtk.Label()
            spacer.set_hexpand(True)
            actions_box.append(spacer)
            actions_box.append(copy_btn)
            
            content_box.append(actions_box)
            bubble_box.append(content_box)
            
            row.append(avatar)
            row.append(bubble_box)
            
        else: # system
            row.set_halign(Gtk.Align.CENTER)
            lbl = Gtk.Label(label=content)
            lbl.add_css_class("message-bubble-system")
            row.append(lbl)

        revealer = Gtk.Revealer()
        revealer.set_transition_type(Gtk.RevealerTransitionType.SLIDE_UP)
        revealer.set_transition_duration(250)
        revealer.set_child(row)

        self.messages_box.append(revealer)
        GLib.idle_add(lambda: revealer.set_reveal_child(True))
        GLib.idle_add(self._scroll_to_bottom)

    def _render_message_content(self, content: str) -> Gtk.Widget:
        container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        
        # Leve parser de markdown para blocos de código
        parts = content.split("```")
        for i, part in enumerate(parts):
            if i % 2 == 1 and i < len(parts) - 1: # Bloco de código
                lines = part.split("\\n", 1)
                lang = lines[0].strip() if len(lines) > 1 else ""
                code = lines[1].strip() if len(lines) > 1 else lines[0].strip()
                container.append(self._create_code_block(code, lang))
            else: # Texto normal
                if not part.strip():
                    continue
                lbl = Gtk.Label()
                # Aplica bold simples (naive) substituindo ** por tags <b>
                parsed_text = part
                if "**" in parsed_text:
                    parsed_text = parsed_text.replace("**", "<b>", 1).replace("**", "</b>", 1)
                
                try:
                    lbl.set_markup(parsed_text)
                except Exception:
                    lbl.set_text(part)
                
                lbl.set_wrap(True)
                lbl.set_selectable(True)
                lbl.set_halign(Gtk.Align.START)
                container.append(lbl)
                
        return container

    def _create_code_block(self, code: str, language: str = "") -> Gtk.Widget:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("code-card")
        
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        header.add_css_class("code-header")
        
        lang_lbl = Gtk.Label(label=language or "code")
        lang_lbl.add_css_class("dim-label")
        header.append(lang_lbl)
        
        spacer = Gtk.Label()
        spacer.set_hexpand(True)
        header.append(spacer)
        
        copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
        copy_btn.add_css_class("flat")
        copy_btn.add_css_class("circular")
        copy_btn.set_tooltip_text("Copiar código")
        copy_btn.connect("clicked", lambda _, txt=code: self._copy_to_clipboard(txt, "Código copiado"))
        header.append(copy_btn)
        
        card.append(header)
        
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.NEVER)
        
        code_lbl = Gtk.Label(label=code)
        code_lbl.set_halign(Gtk.Align.START)
        code_lbl.set_selectable(True)
        code_lbl.add_css_class("code-content")
        scroll.set_child(code_lbl)
        
        card.append(scroll)
        return card

    def _scroll_to_bottom(self) -> bool:
        if self.scroller is not None:
            adj = self.scroller.get_vadjustment()
            if adj.get_upper() - adj.get_value() <= adj.get_page_size() + 150:
                adj.set_value(adj.get_upper() - adj.get_page_size())
        return False

    def _set_loading(self, loading: bool, status: str) -> None:
        self._is_generating = loading
        if self.spinner:
            if loading:
                self.spinner.start()
            else:
                self.spinner.stop()
        
        if self.send_button:
            self.send_button.set_sensitive(not loading)
            self.send_button.set_visible(not loading)
            
        if self.cancel_button:
            self.cancel_button.set_visible(loading)
            
        if self.input:
            self.input.set_sensitive(not loading)
            if not loading:
                self.input.grab_focus()
                
        self._set_status(status)

    def _cancel_generation(self, *_args) -> None:
        self._cancel_requested = True
        self._set_loading(False, "Pronto")
        self._toast("Geração cancelada")
        print("[GTK] Generation canceled")

    def _check_status(self) -> None:
        def worker() -> None:
            try:
                data = self._get_json("/api/applet/status", timeout=4)
                GLib.idle_add(self._apply_status, data)
            except Exception as exc:
                GLib.idle_add(self._apply_status_error, str(exc))
        threading.Thread(target=worker, daemon=True).start()

    def _apply_status(self, data: dict) -> bool:
        self._last_status = data
        if self.banner:
            self.banner.set_revealed(False)
        self._set_status("Pronto")
        print("[GTK] Backend status: online")
        return False

    def _apply_status_error(self, error: str) -> bool:
        if self.banner:
            self.banner.set_revealed(True)
        self._set_status("Backend offline")
        print(f"[GTK] Network error: {error}")
        return False

    def _send_message(self, *_args) -> None:
        if self.input is None or self._is_generating:
            return
        text = self.input.get_text().strip()
        if not text:
            return
            
        self.input.set_text("")
        self._add_message("user", text)
        self._set_loading(True, "Gerando resposta...")
        self._cancel_requested = False
        print("[GTK] Sending message")

        threading.Thread(target=self._request_worker, args=(text,), daemon=True).start()

    def _request_worker(self, text: str) -> None:
        started = time.perf_counter()
        payload = {
            "message": text,
            "source": "cinnamon_gtk_chat",
            "client_id": "zeus_gtk_chat",
        }
        try:
            data = self._post_json("/api/applet/chat", payload, timeout=120)
            if self._cancel_requested:
                return
            
            reply = data.get("reply") or data.get("error") or "Sem resposta."
            speech_reply = data.get("speech_reply") or speech_text(str(reply))
            latency_ms = data.get("latency_ms") or round((time.perf_counter() - started) * 1000)
            
            GLib.idle_add(self._on_response, str(reply), int(latency_ms), str(speech_reply or reply))
        except urllib.error.HTTPError as exc:
            if self._cancel_requested: return
            try: body = exc.read().decode("utf-8")
            except Exception: body = str(exc)
            GLib.idle_add(self._on_error, body)
        except Exception as exc:
            if self._cancel_requested: return
            GLib.idle_add(self._on_error, str(exc))

    def _on_response(self, reply: str, latency_ms: int, speech_reply: str) -> bool:
        self._add_message("assistant", reply)
        self._set_loading(False, "Pronto")
        print("[GTK] Response received")
        if self._voice_enabled:
            self._speak_async(speech_reply)
        return False

    def _on_error(self, error: str) -> bool:
        self._toast(f"Erro de rede: {error}")
        self._set_loading(False, "Erro")
        print(f"[GTK] Network error: {error}")
        self.banner.set_revealed(True)
        return False

    def _speak_async(self, text: str) -> None:
        def worker() -> None:
            try:
                data = self._post_json("/api/tts", {"text": text}, timeout=45)
                audio = data.get("audio") or ""
                if audio and not self._cancel_requested:
                    self._play_audio(audio)
            except Exception as exc:
                print(f"[GTK] TTS Error: {exc}")
        threading.Thread(target=worker, daemon=True).start()

    def _play_audio(self, audio_b64: str) -> None:
        raw = base64.b64decode(audio_b64)
        with tempfile.NamedTemporaryFile(prefix="zeus-tts-", suffix=".mp3", delete=False) as tmp:
            tmp.write(raw)
            path = tmp.name
        player = _find_player()
        if not player:
            GLib.idle_add(self._toast, "Instale ffplay ou mpv para tocar voz.")
            return
        if os.path.basename(player) == "ffplay":
            args = [player, "-nodisp", "-autoexit", "-loglevel", "quiet", path]
        elif os.path.basename(player) == "mpv":
            args = [player, "--no-terminal", path]
        else:
            args = [player, path]
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)

    def _get_json(self, path: str, *, timeout: int) -> dict:
        with urllib.request.urlopen(BACKEND + path, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

    def _post_json(self, path: str, payload: dict, *, timeout: int) -> dict:
        req = urllib.request.Request(
            BACKEND + path,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

def _find_player() -> str | None:
    for name in ("ffplay", "mpv"):
        path = shutil_which(name)
        if path:
            return path
    return None

def shutil_which(name: str) -> str | None:
    for folder in os.getenv("PATH", "").split(os.pathsep):
        candidate = os.path.join(folder, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None

def main() -> int:
    app = ZeusGtkChat()
    return app.run(sys.argv)

if __name__ == "__main__":
    raise SystemExit(main())
