    def _update_contextual_placeholder(self) -> bool:
        if not self._last_status or self._is_generating:
            return True
            
        cog = self._last_status.get("cognitive", {})
        mode = cog.get("mode", "nominal")
        context = str(self._last_status.get("perception", {}).get("visual_context", ""))
        
        placeholder = "Peça uma ação ou diagnóstico..."
        if "deep_work" in mode:
            placeholder = "Modo Deep Work ativo. Como posso acelerar seu código?"
        elif "terminal" in context.lower():
            placeholder = "Vi que está no terminal. Precisa de ajuda com algum comando?"
        elif "code" in context.lower() or "cursor" in context.lower():
            placeholder = "Analisando seu código... Deseja um refactor ou teste?"
        
        if self.input:
            self.input.set_placeholder_text(placeholder)
        return True

