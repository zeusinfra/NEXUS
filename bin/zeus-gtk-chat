        self.cpu_level.set_value(0)
        self.cpu_level.add_css_class("metric-bar")
        self.sidebar.append(self.cpu_level)

        self.ram_label = Gtk.Label(label="RAM   ·  0%")
        self.ram_label.add_css_class("sidebar-metric")
        self.ram_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.ram_label)

        self.ram_level = Gtk.LevelBar()
        self.ram_level.set_min_value(0)
        self.ram_level.set_max_value(100)
        self.ram_level.set_value(0)
        self.ram_level.add_css_class("metric-bar")
        self.sidebar.append(self.ram_level)

        sep2 = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep2.add_css_class("sidebar-sep")
        self.sidebar.append(sep2)

        # -- COGNITIVE STATE --
        cog_title = Gtk.Label(label="ESTADO COGNITIVO")
        cog_title.add_css_class("sidebar-section-title")
        cog_title.set_halign(Gtk.Align.START)
        self.sidebar.append(cog_title)

        self.mode_label = Gtk.Label(label="Modo: BALANCED")
        self.mode_label.add_css_class("sidebar-value")
        self.mode_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.mode_label)

        self.context_label = Gtk.Label(label="Foco: IDLE")
        self.context_label.add_css_class("sidebar-value")
