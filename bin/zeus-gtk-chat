    def _toast(self, message: str, timeout: int = 3) -> None:
        if self.toast_overlay:
            toast = Adw.Toast.new(message)
            toast.set_timeout(timeout)
            self.toast_overlay.add_toast(toast)
        else:
            print(f"[GTK][Toast fallback] {message}")

    def _set_status(self, subtitle: str) -> None:
        if self.window_title:
            self.window_title.set_subtitle(subtitle)

    def _show_diagnostic(self, *_args) -> None:
        provider = self._last_status.get("llm", {}).get("provider", "desconhecido")
        is_online = bool(self._last_status) and not self.banner.get_revealed()
        msg = f"Backend: {'Online' if is_online else 'Offline'}\\nModo: leve\\nLLM: {provider}"
        self._toast(msg, timeout=4)

    def _on_key_press(self, controller, keyval, keycode, state) -> bool:
        if keyval in (Gdk.KEY_l, Gdk.KEY_L) and (state & Gdk.ModifierType.CONTROL_MASK):
            self._clear_messages()
            return True
        if keyval == Gdk.KEY_Escape and self._is_generating:
            self._cancel_generation()
            return True
        return False

    def _clear_messages(self) -> None:
        if self.messages_box is not None:
            while self.messages_box.get_first_child() is not None:
                self.messages_box.remove(self.messages_box.get_first_child())
            self.status_page.set_visible(True)
            self._add_message("system", "Chat limpo localmente.")

    def _toggle_voice(self, button: Gtk.ToggleButton) -> None:
        self._voice_enabled = button.get_active()
        self._toast(f"Voz {'ativada' if self._voice_enabled else 'desativada'}")

    def _copy_to_clipboard(self, text: str, label: str = "Copiado") -> None:
        clipboard = Gdk.Display.get_default().get_clipboard()
        clipboard.set(text)
        self._toast(label)

    def _trigger_autostart_greeting(self) -> bool:
        if not self._is_generating and self.input:
            prompt = "INICIALIZAÇÃO DO SISTEMA: Dê as boas-vindas. Faça um diagnóstico detalhado do uso do PC (CPU, RAM, disco) e do status atual do sistema local usando suas ferramentas. Responda num tom de copiloto pronto para o trabalho."
            self.input.set_text(prompt)
            self._send_message(self.send_button)
            self.input.set_text("")
        return False

    def _add_message(self, role: str, content: str) -> None:
        if self.status_page and self.status_page.get_visible():
            self.status_page.set_visible(False)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.add_css_class("message-row")
        
        timestamp = datetime.now().strftime("%H:%M")

        if role == "user":
            row.set_halign(Gtk.Align.END)
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-user")
            
            label = Gtk.Label(label=f"» {content}")
            label.set_wrap(True)
            label.set_selectable(True)
            label.set_halign(Gtk.Align.START)
            content_box.append(label)
            
            meta = Gtk.Label(label=timestamp)
            meta.add_css_class("message-meta")
            meta.add_css_class("message-meta-user")
            meta.set_halign(Gtk.Align.END)
            content_box.append(meta)
            
            bubble_box.append(content_box)
            
            avatar = Adw.Avatar(text="U", size=36, show_initials=True)
            
            row.append(bubble_box)
            row.append(avatar)
            
        elif role == "assistant":
            row.set_halign(Gtk.Align.START)
            
            avatar = Adw.Avatar(text="Z", size=36, show_initials=True)
            
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            bubble_box.set_hexpand(True)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-assistant")
            
            rendered_content = self._render_message_content(content)
            content_box.append(rendered_content)
            
            actions_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            actions_box.set_margin_top(6)
            
            meta = Gtk.Label(label=f"ZEUS · {timestamp}")
            meta.add_css_class("message-meta")
            actions_box.append(meta)
            
            copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
            copy_btn.add_css_class("flat")
            copy_btn.add_css_class("circular")
            copy_btn.set_tooltip_text("Copiar mensagem")
            copy_btn.connect("clicked", lambda _, txt=content: self._copy_to_clipboard(txt, "Mensagem copiada"))
            
            spacer = Gtk.Label()
            spacer.set_hexpand(True)
            actions_box.append(spacer)
            actions_box.append(copy_btn)
            
            content_box.append(actions_box)
            bubble_box.append(content_box)
            
            row.append(avatar)
            row.append(bubble_box)
            
        else: # system
            row.set_halign(Gtk.Align.CENTER)
            lbl = Gtk.Label(label=content)
            lbl.add_css_class("message-bubble-system")
            row.append(lbl)

        revealer = Gtk.Revealer()
        revealer.set_transition_type(Gtk.RevealerTransitionType.SLIDE_UP)
        revealer.set_transition_duration(250)
        revealer.set_child(row)

        self.messages_box.append(revealer)
        GLib.idle_add(lambda: revealer.set_reveal_child(True))
        GLib.idle_add(self._scroll_to_bottom)

    def _render_message_content(self, content: str) -> Gtk.Widget:
        container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        
        # Leve parser de markdown para blocos de código
        parts = content.split("```")
        for i, part in enumerate(parts):
            if i % 2 == 1 and i < len(parts) - 1: # Bloco de código
                lines = part.split("\\n", 1)
                lang = lines[0].strip() if len(lines) > 1 else ""
                code = lines[1].strip() if len(lines) > 1 else lines[0].strip()
                container.append(self._create_code_block(code, lang))
            else: # Texto normal
                if not part.strip():
                    continue
                lbl = Gtk.Label()
                # Aplica bold simples (naive) substituindo ** por tags <b>
                parsed_text = f"» {part}" if i == 0 else part
                if "**" in parsed_text:
                    parsed_text = parsed_text.replace("**", "<b>", 1).replace("**", "</b>", 1)
                
                try:
                    lbl.set_markup(parsed_text)
                except Exception:
                    lbl.set_text(part)
                
                lbl.set_wrap(True)
                lbl.set_selectable(True)
                lbl.set_halign(Gtk.Align.START)
                container.append(lbl)
                
        return container

    def _create_code_block(self, code: str, language: str = "") -> Gtk.Widget:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("code-card")
        
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        header.add_css_class("code-header")
        
        lang_lbl = Gtk.Label(label=language or "code")
        lang_lbl.add_css_class("dim-label")
        header.append(lang_lbl)
        
        spacer = Gtk.Label()
        spacer.set_hexpand(True)
        header.append(spacer)
        
        copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
        copy_btn.add_css_class("flat")
        copy_btn.add_css_class("circular")
        copy_btn.set_tooltip_text("Copiar código")
        copy_btn.connect("clicked", lambda _, txt=code: self._copy_to_clipboard(txt, "Código copiado"))
        header.append(copy_btn)
        
        card.append(header)
        
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.NEVER)
        
        code_lbl = Gtk.Label(label=code)
        code_lbl.set_halign(Gtk.Align.START)
        code_lbl.set_selectable(True)
        code_lbl.add_css_class("code-content")
        scroll.set_child(code_lbl)
        
        card.append(scroll)
        return card

    def _scroll_to_bottom(self) -> bool:
        if self.scroller is not None:
            adj = self.scroller.get_vadjustment()
            if adj.get_upper() - adj.get_value() <= adj.get_page_size() + 150:
                adj.set_value(adj.get_upper() - adj.get_page_size())
        return False

    def _set_loading(self, loading: bool, status: str) -> None:
        self._is_generating = loading
        if self.spinner:
            if loading:
                self.spinner.start()
            else:
                self.spinner.stop()
        
        if self.send_button:
            self.send_button.set_sensitive(not loading)
            self.send_button.set_visible(not loading)
            
        if self.cancel_button:
            self.cancel_button.set_visible(loading)
            
        if self.input:
            self.input.set_sensitive(not loading)
            if not loading:
                self.input.grab_focus()
                
        self._set_status(status)

    def _cancel_generation(self, *_args) -> None:
        self._cancel_requested = True
        self._set_loading(False, "Pronto")
        self._toast("Geração cancelada")
        print("[GTK] Generation canceled")

    def _check_status(self) -> None:
        def worker() -> None:
            try:
                data = self._get_json("/api/applet/status", timeout=4)
                GLib.idle_add(self._apply_status, data)
            except Exception as exc:
                GLib.idle_add(self._apply_status_error, str(exc))
        threading.Thread(target=worker, daemon=True).start()

    def _poll_status(self) -> bool:
        """Called every 2s by GLib.timeout_add. Returns True to keep polling."""
        self._check_status()
        return True  # Return True = keep the timer alive

    def _apply_status(self, data: dict) -> bool:
        self._last_status = data
        if self.banner:
            self.banner.set_revealed(False)
        
        # Sidebar Telemetry
        api_status = data.get("api_status", {})
        cpu = api_status.get("cpu", 0)
        ram = api_status.get("ram", 0)
        
        if hasattr(self, 'cpu_label'):
            self.cpu_label.set_label(f"CPU   ·  {cpu}%")
        if hasattr(self, 'cpu_level'):
            self.cpu_level.set_value(min(100, max(0, cpu)))
        if hasattr(self, 'ram_label'):
            self.ram_label.set_label(f"RAM   ·  {ram}%")
        if hasattr(self, 'ram_level'):
            self.ram_level.set_value(min(100, max(0, ram)))
            
        cog = data.get("cognitive", {})
        att_state = cog.get("attention", "idle").upper()
        
        # Sidebar Focus & Mode
        if hasattr(self, 'context_label'):
            self.context_label.set_label(f"Foco: {att_state}")
        if hasattr(self, 'mode_label'):
            mode = cog.get("mode", "BALANCED").upper()
            self.mode_label.set_label(f"Modo: {mode}")
            
        # Tradução amigável para o GTK
        att_map = {
            "IDLE": "Pronto",
            "DEEP_FOCUS": "Foco Profundo",
            "DEVELOPMENT": "Desenvolvimento",
            "MINING": "Mineração de Dados",
            "SECURITY": "Proteção Ativa"
        }
        status_text = att_map.get(att_state, att_state.capitalize())
        self._set_status(status_text)
        
        # Privacy Icon
        if self.privacy_icon:
            if cog.get("privacy_shield") == "active":
                self.privacy_icon.set_from_icon_name("security-high-symbolic")
                self.privacy_icon.remove_css_class("dim-label")
                self.privacy_icon.add_css_class("success")
            else:
                self.privacy_icon.set_from_icon_name("security-low-symbolic")
                self.privacy_icon.add_css_class("dim-label")
                self.privacy_icon.remove_css_class("success")

        # Update Thought Bar
        events = data.get("perception", {}).get("recent_events", [])
        if events:
            last_event = events[0]
            thought = f"⚡ {last_event.get('event_type')} | {last_event.get('status')}"
            self.thought_bar.set_label(thought.upper())
        elif att_state == "ACTIVE":
            self.thought_bar.set_label("◉ PROCESSANDO INFORMAÇÃO NEURAL...")
        else:
            self.thought_bar.set_label("◎ SISTEMA NOMINAL | AGUARDANDO COMANDO")

        print(f"[GTK] Backend status: online (Attention: {att_state})")
        return False

    def _apply_status_error(self, error: str) -> bool:
        if self.banner:
            self.banner.set_revealed(True)
        self._set_status("Backend offline")
        print(f"[GTK] Network error: {error}")
        return False

    def _send_message(self, *_args) -> None:
        if self.input is None or self._is_generating:
            return
        text = self.input.get_text().strip()
        if not text:
            return
            
        self.input.set_text("")
        self._add_message("user", text)
        self._set_loading(True, "Gerando resposta...")
        self._cancel_requested = False
        print("[GTK] Sending message")

        threading.Thread(target=self._request_worker, args=(text,), daemon=True).start()

    def _request_worker(self, text: str) -> None:
        started = time.perf_counter()
        payload = {
            "message": text,
            "source": "cinnamon_gtk_chat",
            "client_id": "zeus_gtk_chat",
        }
        try:
            data = self._post_json("/api/applet/chat", payload, timeout=120)
            if self._cancel_requested:
                return
            
            reply = data.get("reply") or data.get("error") or "Sem resposta."
            speech_reply = data.get("speech_reply") or speech_text(str(reply))
            latency_ms = data.get("latency_ms") or round((time.perf_counter() - started) * 1000)
            
            GLib.idle_add(self._on_response, str(reply), int(latency_ms), str(speech_reply or reply))
        except urllib.error.HTTPError as exc:
            if self._cancel_requested: return
            try: body = exc.read().decode("utf-8")
            except Exception: body = str(exc)
            GLib.idle_add(self._on_error, body)
        except Exception as exc:
            if self._cancel_requested: return
            GLib.idle_add(self._on_error, str(exc))

    def _on_response(self, reply: str, latency_ms: int, speech_reply: str) -> bool:
        self._add_message("assistant", reply)
        self._set_loading(False, "Pronto")
        print("[GTK] Response received")
        if self._voice_enabled:
            self._speak_async(speech_reply)
        return False

    def _on_error(self, error: str) -> bool:
        self._toast(f"Erro de rede: {error}")
        self._set_loading(False, "Erro")
        print(f"[GTK] Network error: {error}")
        self.banner.set_revealed(True)
        return False

    def _speak_async(self, text: str) -> None:
        def worker() -> None:
            try:
                data = self._post_json("/api/tts", {"text": text}, timeout=45)
                audio = data.get("audio") or ""
                if audio and not self._cancel_requested:
                    self._play_audio(audio)
            except Exception as exc:
                print(f"[GTK] TTS Error: {exc}")
        threading.Thread(target=worker, daemon=True).start()

    def _play_audio(self, audio_b64: str) -> None:
        raw = base64.b64decode(audio_b64)
        with tempfile.NamedTemporaryFile(prefix="zeus-tts-", suffix=".mp3", delete=False) as tmp:
            tmp.write(raw)
            path = tmp.name
        player = _find_player()
        if not player:
            GLib.idle_add(self._toast, "Instale ffplay ou mpv para tocar voz.")
            return
        if os.path.basename(player) == "ffplay":
            args = [player, "-nodisp", "-autoexit", "-loglevel", "quiet", path]
        elif os.path.basename(player) == "mpv":
            args = [player, "--no-terminal", path]
        else:
            args = [player, path]
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)

    def _get_json(self, path: str, *, timeout: int) -> dict:
        with urllib.request.urlopen(BACKEND + path, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

    def _post_json(self, path: str, payload: dict, *, timeout: int) -> dict:
        req = urllib.request.Request(
            BACKEND + path,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

def _find_player() -> str | None:
    for name in ("ffplay", "mpv"):
        path = shutil_which(name)
        if path:
            return path
    return None

def shutil_which(name: str) -> str | None:
    for folder in os.getenv("PATH", "").split(os.pathsep):
        candidate = os.path.join(folder, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None

def main() -> int:
    app = ZeusGtkChat()
    return app.run(sys.argv)

if __name__ == "__main__":
    raise SystemExit(main())
