#!/usr/bin/env python3
import time
import requests
import os
import sys
from datetime import datetime
from rich.console import Console
from rich.table import Table
from rich.panel import Panel
from rich.text import Text

from collections import deque

BACKEND = os.getenv("NEXUS_BACKEND_URL", "http://127.0.0.1:8080").rstrip("/")
console = Console()
command_history = []
synapse_history = deque(maxlen=20) # Histórico para o gráfico de pulso

def render_sparkline(data):
    """Gera um gráfico ASCII simples para atividade neural."""
    if len(data) < 2: return " "
    chars = " ▂▃▄▅▆▇█"
    min_v = min(data)
    max_v = max(data)
    rng = max_v - min_v
    if rng == 0: return "█" * len(data)
    
    line = ""
    for v in data:
        idx = int(((v - min_v) / rng) * (len(chars) - 1))
        line += chars[idx]
    return line

def get_data():
    try:
        r = requests.get(f"{BACKEND}/api/applet/status", timeout=1.5)
        res = r.json()
        if res and "cognitive" in res:
            synapse_history.append(res["cognitive"].get("synapse_count", 0))
        return res
    except:
        return None

def draw_interface(data):
    console.clear()
    
    # Header
    grid = Table.grid(expand=True)
    grid.add_column(ratio=1)
    grid.add_column(justify="right")
    grid.add_row(
        Text("NEXUS COGNITIVE OS [v4.5]", style="bold green"),
        Text(datetime.now().strftime("%H:%M:%S"), style="bold white"),
    )
    console.print(Panel(grid, style="green"))

    # Body
    if not data:
        console.print(Panel("[bold red]BACKEND OFFLINE / DISCONNECTED[/bold red]", border_style="red"))
    else:
        # Telemetry & Security
        sys_data = data.get("api_status", {}).get("system", {})
        cog = data.get("cognitive", {})
        sync = data.get("sync", {})
        shield = cog.get("privacy_shield", "OFF")
        
        telemetry = Table.grid(expand=True)
        telemetry.add_row(f"[bold cyan]ATTENTION:[/bold cyan] {cog.get('attention', 'IDLE').upper()}")
        telemetry.add_row(f"[bold cyan]SYNAPSES:[/bold cyan]  {cog.get('synapse_count', 0)}")
        telemetry.add_row(f"[bold cyan]PULSE:[/bold cyan]     [magenta]{render_sparkline(list(synapse_history))}[/magenta]")
        telemetry.add_row(f"[bold white]CPU/RAM:[/bold white]   {sys_data.get('cpu_avg', 0)}% / {sys_data.get('ram', 0)}%")
        
        shield_style = "bold green" if shield == "active" else "bold red"
        security = Table.grid(expand=True)
        security.add_row(f"[bold white]SHIELD:[/bold white] [{shield_style}]{shield.upper()}[/{shield_style}]")
        security.add_row(f"[bold cyan]SYNC:[/bold cyan]   {'[green]READY[/green]' if sync.get('is_running') else '[yellow]OFF[/yellow]'}")
        
        # Goals
        goals_table = Table(box=None, expand=True)
        goals_table.add_column("!", style="cyan", width=2)
        goals_table.add_column("ACTIVE GOALS", style="white")
        g_list = cog.get("active_goals_list", [])
        if not g_list:
            goals_table.add_row("", "[dim]IDLE[/dim]")
        else:
            for g in g_list[:5]:
                goals_table.add_row("»", g.get("title", "Ops")[:50])

        # Render layout
        main_grid = Table.grid(expand=True)
        main_grid.add_column(ratio=1)
        main_grid.add_column(ratio=1)
        main_grid.add_row(
            Panel(telemetry, title="NEURAL_STATS", border_style="cyan"),
            Panel(security, title="SECURITY_SYNC", border_style="green")
        )
        console.print(main_grid)
        console.print(Panel(goals_table, title="COGNITIVE_PIPELINE", border_style="green"))

    # Logs
    events = data.get("api_status", {}).get("recent_events", []) if data else []
    log_text = Text()
    if not events:
        log_text.append("> STANDBY / WAITING FOR NEURAL INPUT...\n", style="dim green")
    else:
        for ev in events[:8]:
            etype = ev.get('event_type', 'UNKNOWN').upper()
            # Tradução para termos biológicos
            etype = etype.replace("ACCESS", "ASSIMILATE").replace("CREATE", "GENESIS").replace("DELETE", "PURGE")
            log_text.append(f"» {etype:<15} | {ev.get('status', 'OK')}\n", style="green")
    console.print(Panel(log_text, title="SYNAPTIC_STREAM", border_style="green"))
    
    console.print(Text("ENTER COMMAND | 'r' REFRESH | 'history' | CTRL+C EXIT", justify="center", style="dim green"))

def main():
    while True:
        try:
            data = get_data()
            draw_interface(data)
            
            cmd = console.input("[bold green]nexus@ops[/bold green]:[bold white]~$ [/bold white]")
            
            if not cmd.strip() or cmd.lower() == 'r':
                continue
                
            if cmd.lower() in ["exit", "quit"]:
                break
                
            if cmd.lower() == "history":
                console.print("\n".join(command_history[-10:]))
                time.sleep(2)
                continue

            command_history.append(cmd)
            try:
                requests.post(f"{BACKEND}/api/applet/chat", json={"message": cmd, "source": "tui"}, timeout=2)
            except:
                pass
                
        except KeyboardInterrupt:
            break
        except Exception as e:
            console.print(f"[red]Error: {e}[/red]")
            time.sleep(2)

if __name__ == "__main__":
    main()
