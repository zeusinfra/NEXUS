#!/usr/bin/env python3
import sys
import requests
import os

BACKEND = os.getenv("ZEUS_BACKEND_URL", "http://127.0.0.1:8080").rstrip("/")

def get_suggestion(last_cmd):
    payload = {
        "text": f"Baseado no contexto atual e no último comando '{last_cmd}', sugira o próximo comando de terminal mais provável. Responda APENAS o comando, sem explicações.",
        "context": "terminal_ghosting"
    }
    try:
        r = requests.post(f"{BACKEND}/api/message", json=payload, timeout=2)
        suggestion = r.json().get("text", "").strip()
        # Remove markdown if any
        suggestion = suggestion.replace("`", "").split("\n")[0]
        return suggestion
    except:
        return ""

if __name__ == "__main__":
    last = sys.argv[1] if len(sys.argv) > 1 else ""
    print(get_suggestion(last))
