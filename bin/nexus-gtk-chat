        self.voice_button.set_active(True)
        self.voice_button.set_tooltip_text("Alternar Voz")
        self.voice_button.connect("toggled", self._toggle_voice)
        header.pack_end(self.voice_button)

        # HUD Button
        hud_button = Gtk.Button(icon_name="applications-internet-symbolic")
        hud_button.set_tooltip_text("Abrir HUD Web")
        hud_button.connect("clicked", lambda _: webbrowser.open(BACKEND))
        header.pack_end(hud_button)

        diag_button = Gtk.Button(icon_name="dialog-information-symbolic")
        diag_button.set_tooltip_text("Diagnóstico do NEXUS")
        diag_button.connect("clicked", self._show_diagnostic)
        header.pack_start(diag_button)

        # Privacy Shield Icon
        self.privacy_icon = Gtk.Image.new_from_icon_name("security-high-symbolic")
        self.privacy_icon.set_tooltip_text("Cognitive Shield Ativo")
        self.privacy_icon.add_css_class("dim-label")
        header.pack_start(self.privacy_icon)

        # Banner for Offline status
        self.banner = Adw.Banner()
        self.banner.set_title("Backend NEXUS offline. Verifique se o serviço está ativo.")
        self.banner.set_button_label("Tentar novamente")
        self.banner.connect("button-clicked", lambda _: self._check_status())
        self.chat_area.append(self.banner)

        # Scroller
        self.scroller = Gtk.ScrolledWindow()
        self.scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.scroller.set_vexpand(True)
        self.scroller.add_css_class("chat-scroll")
        self.chat_area.append(self.scroller)

        # Clamp for centered reading
        clamp = Adw.Clamp()
        clamp.set_maximum_size(960)
        clamp.set_tightening_threshold(700)
        
        self.scroller.set_child(clamp)

        # Box for messages
        self.messages_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=16)
        self.messages_box.set_margin_top(24)
        self.messages_box.set_margin_bottom(24)
        self.messages_box.set_margin_start(16)
        self.messages_box.set_margin_end(16)
        
        # Empty State
        self.status_page = Adw.StatusPage()
