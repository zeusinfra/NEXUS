            row.append(check)
            row.append(lbl)
            self.sidebar.append(row)

        self.main_container.append(sidebar_scroll)

        # RIGHT PANEL (Chat Area)
        self.chat_area = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
