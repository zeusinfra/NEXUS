        self.status_page.set_title("NEXUS pronto")
        self.status_page.set_description("Digite uma mensagem para iniciar.")
        self.status_page.add_css_class("empty-state")
        
        overlay_box = Gtk.Overlay()
        overlay_box.set_child(self.messages_box)
        overlay_box.add_overlay(self.status_page)
        clamp.set_child(overlay_box)

        # Composer area
        composer_clamp = Adw.Clamp()
        composer_clamp.set_maximum_size(960)
        composer_clamp.set_tightening_threshold(700)

        composer_bg = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        composer_bg.add_css_class("composer-bg")
        composer_bg.append(composer_clamp)
        self.chat_area.append(composer_bg)

        # Thought Bar
        self.thought_bar = Gtk.Label(label="SISTEMA NOMINAL | AGUARDANDO INPUT...")
        self.thought_bar.add_css_class("thought-bar")
        self.thought_bar.set_halign(Gtk.Align.START)
        self.thought_bar.set_margin_start(16)
        self.thought_bar.set_margin_end(16)
        self.thought_bar.set_margin_top(6)
        self.thought_bar.set_margin_bottom(10)
        self.chat_area.append(self.thought_bar)

        composer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        composer.add_css_class("composer")
        composer.set_margin_start(16)
        composer.set_margin_end(16)
        composer.set_margin_top(16)
        composer.set_margin_bottom(24)
        composer_clamp.set_child(composer)

        input_stack = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        input_stack.set_hexpand(True)
        self.input_scroll = Gtk.ScrolledWindow()
        self.input_scroll.add_css_class("composer-input")
        self.input_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.input_scroll.set_min_content_height(44)
        self.input_scroll.set_max_content_height(130)

        self.input = Gtk.TextView()
        self.input.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self.input.set_top_margin(10)
        self.input.set_bottom_margin(10)
        self.input.set_left_margin(12)
        self.input.set_right_margin(12)
        self.input_buffer = self.input.get_buffer()
        self.input_buffer.connect("changed", self._on_input_changed)
        input_key = Gtk.EventControllerKey.new()
        input_key.connect("key-pressed", self._on_input_key_press)
        self.input.add_controller(input_key)
        self.input_scroll.set_child(self.input)
        input_stack.append(self.input_scroll)

        input_footer = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        self.char_count_label = Gtk.Label(label="0")
        self.char_count_label.add_css_class("composer-counter")
        self.char_count_label.set_halign(Gtk.Align.END)
        input_footer.append(Gtk.Label(label="Enter envia · Shift+Enter quebra linha"))
        input_footer.get_first_child().add_css_class("composer-hint")
        spacer_footer = Gtk.Label()
        spacer_footer.set_hexpand(True)
        input_footer.append(spacer_footer)
        input_footer.append(self.char_count_label)
        input_stack.append(input_footer)
        composer.append(input_stack)

        self.spinner = Gtk.Spinner()
        composer.append(self.spinner)

        self.cancel_button = Gtk.Button(icon_name="media-playback-stop-symbolic")
        self.cancel_button.set_tooltip_text("Cancelar geração (Esc)")
        self.cancel_button.add_css_class("destructive-action")
        self.cancel_button.set_visible(False)
        self.cancel_button.connect("clicked", self._cancel_generation)
        composer.append(self.cancel_button)

        self.send_button = Gtk.Button(icon_name="mail-send-symbolic")
        self.send_button.add_css_class("suggested-action")
        self.send_button.set_tooltip_text("Enviar mensagem (Enter)")
        self.send_button.connect("clicked", self._send_message)
        composer.append(self.send_button)

        print("[GTK] App started")
        return window

    def _update_contextual_placeholder(self) -> bool:
        if not self._last_status or self._is_generating:
            return True
        return True

