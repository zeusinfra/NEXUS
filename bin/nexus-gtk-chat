            background-color: #14141a;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 10px;
            padding: 12px 16px;
            color: @text_primary;
            font-size: 0.9rem;
        }

        entry:focus {
            border-color: @accent_color;
            box-shadow: 0 0 0 2px @border_glow;
        }

        /* ========= BUTTONS ========= */
        button.suggested-action {
            background: @accent_color;
            color: #000;
            font-weight: 700;
            border-radius: 10px;
            padding: 8px 14px;
        }

        button.suggested-action:hover {
            background: #00e07a;
            box-shadow: 0 0 16px @border_glow;
        }

        /* ========= CODE BLOCKS ========= */
        .code-card {
            background-color: #0e0e14;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 10px;
            margin: 8px 0;
        }
        .code-header {
            padding: 6px 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }
        .code-content {
            font-family: 'JetBrains Mono', 'Fira Code', monospace;
            font-size: 0.82rem;
            padding: 10px 14px;
            color: #c8d0e0;
        }

        /* ========= EMPTY STATE ========= */
        .empty-state {
            opacity: 0.4;
        }

        /* ========= SCROLLBAR ========= */
        scrollbar slider {
            min-width: 4px;
            min-height: 4px;
            border-radius: 4px;
            background-color: rgba(255, 255, 255, 0.08);
        }
        scrollbar slider:hover {
            background-color: rgba(0, 255, 136, 0.2);
        }
        """
        provider = Gtk.CssProvider()
        provider.load_from_string(css)
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def _toast(self, message: str, timeout: int = 3) -> None:
        if self.toast_overlay:
            toast = Adw.Toast.new(message)
            toast.set_timeout(timeout)
            self.toast_overlay.add_toast(toast)
        else:
            print(f"[GTK][Toast fallback] {message}")

    def _set_status(self, subtitle: str) -> None:
        if self.window_title:
            self.window_title.set_subtitle(subtitle)

    def _init_history_db(self) -> None:
        os.makedirs(os.path.dirname(self._history_db), exist_ok=True)
        with sqlite3.connect(self._history_db) as conn:
            conn.execute(
                """
                CREATE TABLE IF NOT EXISTS gtk_messages (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    session_id TEXT NOT NULL,
                    role TEXT NOT NULL,
                    content TEXT NOT NULL,
                    created_at TEXT NOT NULL
                )
                """
            )

    def _save_local_message(self, role: str, content: str) -> None:
        try:
            with sqlite3.connect(self._history_db) as conn:
                conn.execute(
                    "INSERT INTO gtk_messages(session_id, role, content, created_at) VALUES (?, ?, ?, ?)",
                    (self._session_id, role, content[:12000], datetime.now().isoformat(timespec="seconds")),
                )
        except Exception as exc:
            print(f"[GTK] History save failed: {exc}")

    def _get_input_text(self) -> str:
        if not self.input_buffer:
            return ""
        start = self.input_buffer.get_start_iter()
        end = self.input_buffer.get_end_iter()
        return self.input_buffer.get_text(start, end, True)

    def _set_input_text(self, text: str) -> None:
        if self.input_buffer:
            self.input_buffer.set_text(text)

    def _on_input_changed(self, *_args) -> None:
        if self.char_count_label:
            self.char_count_label.set_label(str(len(self._get_input_text())))

    def _on_input_key_press(self, controller, keyval, keycode, state) -> bool:
        if keyval in (Gdk.KEY_Return, Gdk.KEY_KP_Enter) and not (state & Gdk.ModifierType.SHIFT_MASK):
            self._send_message(self.send_button)
            return True
        return False

    def _toggle_sidebar(self, *_args) -> None:
        self._sidebar_visible = not self._sidebar_visible
        if self.sidebar_scroll:
            self.sidebar_scroll.set_visible(self._sidebar_visible)

    def _show_command_palette(self, *_args) -> None:
        dialog = Gtk.Window(title="Command Palette")
        dialog.set_transient_for(self.window)
        dialog.set_modal(True)
        dialog.set_default_size(420, 360)
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        box.set_margin_top(16)
        box.set_margin_bottom(16)
        box.set_margin_start(16)
        box.set_margin_end(16)
        dialog.set_child(box)

        actions = [
            ("Diagnóstico", self._show_diagnostic),
            ("Mostrar histórico da sessão", self._show_session_history),
            ("Limpar chat", self._clear_messages),
            ("Abrir HUD Web", lambda *_: webbrowser.open(BACKEND)),
            ("Alternar voz", lambda *_: self.voice_button.set_active(not self.voice_button.get_active()) if self.voice_button else None),
            ("Ocultar/mostrar sidebar", self._toggle_sidebar),
            ("Health check", self._check_status),
        ]
        for label, callback in actions:
            btn = Gtk.Button(label=label)
            btn.set_halign(Gtk.Align.FILL)
            btn.connect("clicked", lambda _btn, cb=callback: (cb(), dialog.close()))
            box.append(btn)
        dialog.present()

    def _show_session_history(self, *_args) -> None:
        dialog = Gtk.Window(title="Histórico local")
        dialog.set_transient_for(self.window)
        dialog.set_modal(True)
        dialog.set_default_size(640, 520)
        scroll = Gtk.ScrolledWindow()
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        box.set_margin_top(16)
        box.set_margin_bottom(16)
        box.set_margin_start(16)
        box.set_margin_end(16)
        scroll.set_child(box)
        dialog.set_child(scroll)
        try:
            with sqlite3.connect(self._history_db) as conn:
                rows = conn.execute(
                    "SELECT role, content, created_at FROM gtk_messages "
                    "WHERE session_id = ? ORDER BY id DESC LIMIT 40",
                    (self._session_id,),
                ).fetchall()
        except Exception as exc:
            rows = [("system", f"Falha ao abrir histórico: {exc}", "")]
        for role, content, created_at in reversed(rows):
            label = Gtk.Label(label=f"{created_at} · {role}\n{content[:1000]}")
            label.set_wrap(True)
            label.set_selectable(True)
            label.set_halign(Gtk.Align.START)
            box.append(label)
        dialog.present()

    def _show_diagnostic(self, *_args) -> None:
        provider = self._last_status.get("llm", {}).get("provider", "desconhecido")
        is_online = bool(self._last_status) and not self.banner.get_revealed()
        msg = f"Backend: {'Online' if is_online else 'Offline'}\\nModo: leve\\nLLM: {provider}"
        self._toast(msg, timeout=4)

    def _on_key_press(self, controller, keyval, keycode, state) -> bool:
        if keyval in (Gdk.KEY_l, Gdk.KEY_L) and (state & Gdk.ModifierType.CONTROL_MASK):
            self._clear_messages()
            return True
        if keyval in (Gdk.KEY_k, Gdk.KEY_K) and (state & Gdk.ModifierType.CONTROL_MASK):
            self._show_command_palette()
            return True
        if keyval == Gdk.KEY_Escape and self._is_generating:
            self._cancel_generation()
            return True
        return False

    def _clear_messages(self) -> None:
        if self.messages_box is not None:
            while self.messages_box.get_first_child() is not None:
                self.messages_box.remove(self.messages_box.get_first_child())
            self.status_page.set_visible(True)
            self._add_message("system", "Chat limpo localmente.")

    def _toggle_voice(self, button: Gtk.ToggleButton) -> None:
        self._voice_enabled = button.get_active()
        self._toast(f"Voz {'ativada' if self._voice_enabled else 'desativada'}")

    def _copy_to_clipboard(self, text: str, label: str = "Copiado") -> None:
        clipboard = Gdk.Display.get_default().get_clipboard()
        clipboard.set(text)
        self._toast(label)

    def _trigger_autostart_greeting(self) -> bool:
        if not self._is_generating and self.input:
            prompt = "INICIALIZAÇÃO DO SISTEMA: Dê as boas-vindas. Faça um diagnóstico detalhado do uso do PC (CPU, RAM, disco) e do status atual do sistema local usando suas ferramentas. Responda num tom de copiloto pronto para o trabalho."
            self._set_input_text(prompt)
            self._send_message(self.send_button)
            self._set_input_text("")
        return False

    def _add_message(self, role: str, content: str) -> None:
        if self.status_page and self.status_page.get_visible():
            self.status_page.set_visible(False)
        if role in {"user", "assistant"}:
            self._save_local_message(role, content)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        row.add_css_class("message-row")
        
        timestamp = datetime.now().strftime("%H:%M")

        if role == "user":
            row.set_halign(Gtk.Align.END)
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-user")

            header = Gtk.Label(label=f"Você · {timestamp}")
            header.add_css_class("message-header")
            header.set_halign(Gtk.Align.END)
            content_box.append(header)
            
            label = Gtk.Label(label=content)
            label.set_wrap(True)
            label.set_selectable(True)
            label.set_halign(Gtk.Align.START)
            content_box.append(label)
            
            meta = Gtk.Label(label=timestamp)
            meta.add_css_class("message-meta")
            meta.add_css_class("message-meta-user")
            meta.set_halign(Gtk.Align.END)
            content_box.append(meta)
            
            bubble_box.append(content_box)
            
            avatar = Adw.Avatar(text="U", size=36, show_initials=True)
            
            row.append(bubble_box)
            row.append(avatar)
            
        elif role == "assistant":
            row.set_halign(Gtk.Align.START)
            
            avatar = Adw.Avatar(text="Z", size=36, show_initials=True)
            
            bubble_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            bubble_box.set_hexpand(True)
            
            content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            content_box.add_css_class("message-bubble")
            content_box.add_css_class("message-bubble-assistant")

            header = Gtk.Label(label=f"NEXUS · {timestamp}")
            header.add_css_class("message-header")
            header.set_halign(Gtk.Align.START)
            content_box.append(header)
            
            rendered_content = self._render_message_content(content)
            content_box.append(rendered_content)
            
            actions_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            actions_box.set_margin_top(6)
            
            meta = Gtk.Label(label=f"{len(content)} chars")
            meta.add_css_class("message-meta")
            actions_box.append(meta)
            
            copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
            copy_btn.add_css_class("flat")
            copy_btn.add_css_class("circular")
            copy_btn.set_tooltip_text("Copiar mensagem")
            copy_btn.connect("clicked", lambda _, txt=content: self._copy_to_clipboard(txt, "Mensagem copiada"))
            speak_btn = Gtk.Button(icon_name="audio-volume-high-symbolic")
            speak_btn.add_css_class("flat")
            speak_btn.add_css_class("circular")
            speak_btn.set_tooltip_text("Falar novamente")
            speak_btn.connect("clicked", lambda _, txt=content: self._speak_async(speech_text(txt) or txt))
            insight_btn = Gtk.Button(icon_name="emblem-favorite-symbolic")
            insight_btn.add_css_class("flat")
            insight_btn.add_css_class("circular")
            insight_btn.set_tooltip_text("Salvar insight local")
            insight_btn.connect("clicked", lambda _, txt=content: self._copy_to_clipboard(txt, "Insight copiado para uso no Second Brain"))
            
            spacer = Gtk.Label()
            spacer.set_hexpand(True)
            actions_box.append(spacer)
            actions_box.append(speak_btn)
            actions_box.append(insight_btn)
            actions_box.append(copy_btn)
            
            content_box.append(actions_box)
            bubble_box.append(content_box)
            
            row.append(avatar)
            row.append(bubble_box)
            
        else: # system
            row.set_halign(Gtk.Align.CENTER)
            lbl = Gtk.Label(label=content)
            lbl.add_css_class("message-bubble-system")
            row.append(lbl)

        revealer = Gtk.Revealer()
        revealer.set_transition_type(Gtk.RevealerTransitionType.SLIDE_UP)
        revealer.set_transition_duration(250)
        revealer.set_child(row)

        self.messages_box.append(revealer)
        GLib.idle_add(lambda: revealer.set_reveal_child(True))
        GLib.idle_add(self._scroll_to_bottom)

    def _add_admin_action_card(self, action: dict) -> None:
        if not self.messages_box:
            return
        if self.status_page and self.status_page.get_visible():
            self.status_page.set_visible(False)

        action_id = str(action.get("id") or "")
        command = str(action.get("command") or "N/A")
        reason = str(action.get("reason") or action.get("rationale") or "Ação administrativa proposta.")
        risk = str(action.get("risk") or "UNKNOWN")
        rollback = str(action.get("rollback_plan") or "Não informado")
        expected = str(action.get("expected_outcome") or "Não informado")

        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        card.add_css_class("admin-card")
        title = Gtk.Label(label=f"Admin Action Required · {risk}")
        title.add_css_class("admin-title")
        title.set_halign(Gtk.Align.START)
        card.append(title)

        cmd = Gtk.Label(label=command)
        cmd.add_css_class("admin-command")
        cmd.set_selectable(True)
        cmd.set_wrap(True)
        cmd.set_halign(Gtk.Align.START)
        card.append(cmd)

        details = Gtk.Label(label=f"Motivo: {reason}\nResultado esperado: {expected}\nRollback: {rollback}")
        details.set_wrap(True)
        details.set_selectable(True)
        details.set_halign(Gtk.Align.START)
        card.append(details)

        buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        deny = Gtk.Button(label="Deny")
        deny.connect("clicked", lambda *_: self._admin_decision(action_id, "deny"))
        allow = Gtk.Button(label="Allow")
        allow.add_css_class("suggested-action")
        allow.connect("clicked", lambda *_: self._admin_decision(action_id, "allow"))
        buttons.append(deny)
        buttons.append(allow)
        card.append(buttons)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        row.set_halign(Gtk.Align.CENTER)
        row.append(card)
        self.messages_box.append(row)
        GLib.idle_add(self._scroll_to_bottom)

    def _admin_decision(self, action_id: str, decision: str) -> None:
        if not action_id:
            self._toast("Ação admin sem ID; não é seguro aprovar.")
            return
        path = f"/api/admin/actions/{action_id}/{'allow' if decision == 'allow' else 'deny'}"
        def worker() -> None:
            try:
                self._post_json(path, {"action_id": action_id}, timeout=30)
                GLib.idle_add(self._toast, f"Ação {decision} registrada.")
            except Exception as exc:
                GLib.idle_add(self._toast, f"Falha ao registrar decisão admin: {exc}", 5)
        threading.Thread(target=worker, daemon=True).start()

    def _render_message_content(self, content: str) -> Gtk.Widget:
        container = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        
        # Leve parser de markdown para blocos de código
        parts = content.split("```")
        for i, part in enumerate(parts):
            if i % 2 == 1 and i < len(parts) - 1: # Bloco de código
                lines = part.split("\\n", 1)
                lang = lines[0].strip() if len(lines) > 1 else ""
                code = lines[1].strip() if len(lines) > 1 else lines[0].strip()
                container.append(self._create_code_block(code, lang))
            else: # Texto normal
                if not part.strip():
                    continue
                lbl = Gtk.Label()
                parsed_text = f"» {part}" if i == 0 else part
                try:
                    lbl.set_markup(pango_markup(parsed_text))
                except Exception:
                    lbl.set_text(part)
                
                lbl.set_wrap(True)
                lbl.set_selectable(True)
                lbl.set_halign(Gtk.Align.START)
                container.append(lbl)
                
        return container

    def _create_code_block(self, code: str, language: str = "") -> Gtk.Widget:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.add_css_class("code-card")
        
        header = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        header.add_css_class("code-header")
        
        lang_lbl = Gtk.Label(label=language or "code")
        lang_lbl.add_css_class("dim-label")
        header.append(lang_lbl)
        
        spacer = Gtk.Label()
        spacer.set_hexpand(True)
        header.append(spacer)
        
        copy_btn = Gtk.Button(icon_name="edit-copy-symbolic")
        copy_btn.add_css_class("flat")
        copy_btn.add_css_class("circular")
        copy_btn.set_tooltip_text("Copiar código")
        copy_btn.connect("clicked", lambda _, txt=code: self._copy_to_clipboard(txt, "Código copiado"))
        header.append(copy_btn)
        
        card.append(header)
        
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.NEVER)
        
        code_lbl = Gtk.Label(label=code)
        code_lbl.set_halign(Gtk.Align.START)
        code_lbl.set_selectable(True)
        code_lbl.add_css_class("code-content")
        scroll.set_child(code_lbl)
        
        card.append(scroll)
        return card

    def _scroll_to_bottom(self) -> bool:
        if self.scroller is not None:
            adj = self.scroller.get_vadjustment()
            if adj.get_upper() - adj.get_value() <= adj.get_page_size() + 150:
                adj.set_value(adj.get_upper() - adj.get_page_size())
        return False

    def _set_loading(self, loading: bool, status: str) -> None:
        self._is_generating = loading
        if self.spinner:
            if loading:
                self.spinner.start()
            else:
                self.spinner.stop()
        
        if self.send_button:
            self.send_button.set_sensitive(not loading)
            self.send_button.set_visible(not loading)
            
        if self.cancel_button:
            self.cancel_button.set_visible(loading)
            
        if self.input:
            self.input.set_sensitive(not loading)
            if not loading:
                self.input.grab_focus()
                
        self._set_status(status)

    def _cancel_generation(self, *_args) -> None:
        self._cancel_requested = True
        self._set_loading(False, "Pronto")
        self._toast("Geração cancelada")
        print("[GTK] Generation canceled")

    def _check_status(self) -> None:
        def worker() -> None:
            try:
                data = self._get_json("/api/applet/status", timeout=4)
                GLib.idle_add(self._apply_status, data)
            except Exception as exc:
                GLib.idle_add(self._apply_status_error, str(exc))
        threading.Thread(target=worker, daemon=True).start()

    def _poll_status(self) -> bool:
        """Called every 2s by GLib.timeout_add. Returns True to keep polling."""
        self._check_status()
        self._check_admin_actions()
        return True  # Return True = keep the timer alive

    def _check_admin_actions(self) -> None:
        def worker() -> None:
            try:
                data = self._get_json("/api/admin/actions/pending", timeout=4)
                for action in data.get("actions", []):
                    action_id = str(action.get("id") or "")
                    if action_id and action_id not in self._seen_admin_action_ids:
                        self._seen_admin_action_ids.add(action_id)
                        GLib.idle_add(self._add_admin_action_card, action)
            except Exception:
                pass
        threading.Thread(target=worker, daemon=True).start()

    def _poll_agent_events(self) -> bool:
        if self._events_polling:
            return True
        self._events_polling = True

        def worker() -> None:
            try:
                query = urllib.parse.urlencode({"client_id": self._client_id})
                data = self._get_json(f"/api/events/drain?{query}", timeout=2)
                events = data.get("events") or []
                if events:
                    GLib.idle_add(self._apply_agent_events, events)
            except Exception:
                pass
            finally:
                self._events_polling = False
        threading.Thread(target=worker, daemon=True).start()
        return True

    def _apply_agent_events(self, events: list[dict]) -> bool:
        for event in events:
            if not isinstance(event, dict):
                continue
            key = json.dumps(
                {
                    "type": event.get("type"),
                    "stage": event.get("stage"),
                    "tool": event.get("tool"),
                    "text": event.get("text"),
                    "id": event.get("id") or (event.get("details") or {}).get("id"),
                },
                sort_keys=True,
                ensure_ascii=False,
            )
            if key in self._seen_event_keys:
                continue
            self._seen_event_keys.add(key)
            if len(self._seen_event_keys) > 200:
                self._seen_event_keys = set(list(self._seen_event_keys)[-120:])
            self._show_agent_event(event)
        return False

    def _show_agent_event(self, event: dict) -> None:
        event_type = str(event.get("type") or "")
        if event_type == "AGENT_PROGRESS":
            text = str(event.get("text") or "").strip()
            stage = str(event.get("stage") or "progress")
            tool = str(event.get("tool") or "").strip()
            if text and hasattr(self, "thought_bar"):
                self.thought_bar.set_label(f"◉ {text}".upper())
            if stage in {"started", "tool_running", "tool_done", "awaiting_confirmation", "chat_failed"}:
                label = f"{stage.replace('_', ' ').title()}"
                if tool:
                    label = f"{label} · {tool}"
                self._add_message("system", f"{label}: {text}")
            if stage in {"chat_completed", "completed"}:
                self._set_status("Pronto")
            elif stage == "chat_failed":
                self._set_status("Erro")
            return

        if event_type == "TOOL_LOG":
            stage = str(event.get("stage") or "tool")
            tool = str(event.get("tool") or "ferramenta")
            if stage == "running":
                self._add_message("system", f"Ferramenta em execução: {tool}")
                self._set_status(f"Executando {tool}")
            elif stage == "done":
                result = event.get("result")
                summary = ""
                if isinstance(result, dict):
                    keys = ", ".join(list(result.keys())[:5])
                    summary = f" · resultado: {keys}" if keys else ""
                self._add_message("system", f"Ferramenta concluída: {tool}{summary}")
            elif stage in {"awaiting_confirmation", "step_failed"}:
                self._add_message("system", f"{tool}: {stage.replace('_', ' ')}")

    def _apply_status(self, data: dict) -> bool:
        self._last_status = data
        if self.banner:
            self.banner.set_revealed(False)
        
        # Sidebar Telemetry
        api_status = data.get("api_status", {})
        cpu = api_status.get("cpu", 0)
        ram = api_status.get("ram", 0)
        for alert in api_status.get("system_alerts", []):
            alert_id = str(alert.get("id") or "")
            if alert_id and alert_id not in self._seen_system_alert_ids:
                self._seen_system_alert_ids.add(alert_id)
                title = alert.get("title") or "Alerta do sistema"
                message = alert.get("message") or ""
                self._add_message("system", f"{title}: {message}")
        
        if hasattr(self, 'cpu_label'):
            self.cpu_label.set_label(f"CPU   ·  {cpu}%")
        if hasattr(self, 'cpu_level'):
            self.cpu_level.set_value(min(100, max(0, cpu)))
        if hasattr(self, 'ram_label'):
            self.ram_label.set_label(f"RAM   ·  {ram}%")
        if hasattr(self, 'ram_level'):
            self.ram_level.set_value(min(100, max(0, ram)))
            
        cog = data.get("cognitive", {})
        att_state = cog.get("attention", "idle").upper()
        
        # Sidebar Focus & Mode
        if hasattr(self, 'context_label'):
            self.context_label.set_label(f"Foco: {att_state}")
        if hasattr(self, 'mode_label'):
            mode = cog.get("mode", "BALANCED").upper()
            self.mode_label.set_label(f"Modo: {mode}")
            
        # Tradução amigável para o GTK
        att_map = {
            "IDLE": "Pronto",
            "DEEP_FOCUS": "Foco Profundo",
            "DEVELOPMENT": "Desenvolvimento",
            "MINING": "Mineração de Dados",
            "SECURITY": "Proteção Ativa"
        }
        status_text = att_map.get(att_state, att_state.capitalize())
        self._set_status(status_text)
        
        # Privacy Icon
        if self.privacy_icon:
            if cog.get("privacy_shield") == "active":
                self.privacy_icon.set_from_icon_name("security-high-symbolic")
                self.privacy_icon.remove_css_class("dim-label")
                self.privacy_icon.add_css_class("success")
            else:
                self.privacy_icon.set_from_icon_name("security-low-symbolic")
                self.privacy_icon.add_css_class("dim-label")
                self.privacy_icon.remove_css_class("success")

        # Update Thought Bar
        events = data.get("perception", {}).get("recent_events", [])
        if events:
            last_event = events[0]
            thought = f"⚡ {last_event.get('event_type')} | {last_event.get('status')}"
            self.thought_bar.set_label(thought.upper())
        elif att_state == "ACTIVE":
            self.thought_bar.set_label("◉ PROCESSANDO INFORMAÇÃO NEURAL...")
        else:
            self.thought_bar.set_label("◎ SISTEMA NOMINAL | AGUARDANDO COMANDO")

        print(f"[GTK] Backend status: online (Attention: {att_state})")
        return False

    def _apply_status_error(self, error: str) -> bool:
        if self.banner:
            self.banner.set_revealed(True)
        self._set_status("Backend offline")
        print(f"[GTK] Network error: {error}")
        return False

    def _send_message(self, *_args) -> None:
        if self.input is None or self._is_generating:
            return
        text = self._get_input_text().strip()
        if not text:
            return
            
        self._set_input_text("")
        self._add_message("user", text)
        self._set_loading(True, "Gerando resposta...")
        self._cancel_requested = False
        print("[GTK] Sending message")

        threading.Thread(target=self._request_worker, args=(text,), daemon=True).start()

    def _request_worker(self, text: str) -> None:
        started = time.perf_counter()
        payload = {
            "message": text,
            "source": "cinnamon_gtk_chat",
            "client_id": self._client_id,
            "session_id": self._session_id,
        }
        try:
            data = self._post_json("/api/applet/chat", payload, timeout=120)
            if self._cancel_requested:
                return
            
            reply = data.get("reply") or data.get("error") or "Sem resposta."
            speech_reply = data.get("speech_reply") or speech_text(str(reply))
            latency_ms = data.get("latency_ms") or round((time.perf_counter() - started) * 1000)
            admin_actions = data.get("admin_actions")
            admin_action = data.get("admin_action")
            if not admin_action and isinstance(admin_actions, list) and admin_actions:
                admin_action = admin_actions[0]
            
            GLib.idle_add(self._on_response, str(reply), int(latency_ms), str(speech_reply or reply), admin_action)
        except urllib.error.HTTPError as exc:
            if self._cancel_requested: return
            try: body = exc.read().decode("utf-8")
            except Exception: body = str(exc)
            GLib.idle_add(self._on_error, body)
        except Exception as exc:
            if self._cancel_requested: return
            GLib.idle_add(self._on_error, str(exc))

    def _on_response(self, reply: str, latency_ms: int, speech_reply: str, admin_action: dict | None = None) -> bool:
        self._add_message("assistant", reply)
        if isinstance(admin_action, dict):
            self._add_admin_action_card(admin_action)
        self._set_loading(False, "Pronto")
        print("[GTK] Response received")
        if self._voice_enabled:
            self._speak_async(speech_reply)
        return False

    def _on_error(self, error: str) -> bool:
        self._toast(f"Erro de rede: {error}")
        self._set_loading(False, "Erro")
        print(f"[GTK] Network error: {error}")
        self.banner.set_revealed(True)
        return False

    def _speak_async(self, text: str) -> None:
        def worker() -> None:
            try:
                data = self._post_json("/api/tts", {"text": text}, timeout=45)
                audio = data.get("audio") or ""
                if audio and not self._cancel_requested:
                    self._play_audio(audio)
            except Exception as exc:
                print(f"[GTK] TTS Error: {exc}")
        threading.Thread(target=worker, daemon=True).start()

    def _play_audio(self, audio_b64: str) -> None:
        raw = base64.b64decode(audio_b64)
        with tempfile.NamedTemporaryFile(prefix="nexus-tts-", suffix=".mp3", delete=False) as tmp:
            tmp.write(raw)
            path = tmp.name
        player = _find_player()
        if not player:
            GLib.idle_add(self._toast, "Instale ffplay ou mpv para tocar voz.")
            return
        if os.path.basename(player) == "ffplay":
            args = [player, "-nodisp", "-autoexit", "-loglevel", "quiet", path]
        elif os.path.basename(player) == "mpv":
            args = [player, "--no-terminal", path]
        else:
            args = [player, path]
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)

    def _get_json(self, path: str, *, timeout: int) -> dict:
        with urllib.request.urlopen(BACKEND + path, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

    def _post_json(self, path: str, payload: dict, *, timeout: int) -> dict:
        req = urllib.request.Request(
            BACKEND + path,
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=timeout) as response:
            return json.loads(response.read().decode("utf-8"))

def _find_player() -> str | None:
    for name in ("ffplay", "mpv"):
        path = shutil_which(name)
        if path:
            return path
    return None

def shutil_which(name: str) -> str | None:
    for folder in os.getenv("PATH", "").split(os.pathsep):
        candidate = os.path.join(folder, name)
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            return candidate
    return None

def main() -> int:
    app = NexusGtkChat()
    return app.run(sys.argv)

if __name__ == "__main__":
    raise SystemExit(main())
