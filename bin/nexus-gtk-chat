#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import base64
import sqlite3
import subprocess
import sys
import tempfile
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
import webbrowser
from datetime import datetime

ROOT_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
if ROOT_DIR not in sys.path:
    sys.path.insert(0, ROOT_DIR)

from nexus_core.response_text import pango_markup, speech_text

try:
    import gi
    gi.require_version("Gdk", "4.0")
    gi.require_version("Gtk", "4.0")
    gi.require_version("Adw", "1")
    from gi.repository import Gdk, Gio, GLib, Gtk, Pango, Adw
    # Inicializar Libadwaita
    Adw.init()
except (ImportError, ValueError):
    print("Erro: GTK4/Adwaita não encontrado. Este chat requer ambiente gráfico Linux.")
    sys.exit(1)

from nexus_core.security.approval_listener import start_approval_listener_glib

# Se o primeiro argumento não começar com '--', assumimos que é a URL do backend.
_backend_arg = sys.argv[1] if len(sys.argv) > 1 and not sys.argv[1].startswith("--") else None
BACKEND = (_backend_arg or os.getenv("NEXUS_BACKEND_URL", "http://127.0.0.1:8080")).rstrip("/")
APP_ID = "local.nexus.CognitiveChat"


class NexusGtkChat(Adw.Application):
    def __init__(self) -> None:
        super().__init__(application_id=APP_ID, flags=Gio.ApplicationFlags.HANDLES_COMMAND_LINE)
        self.window: Adw.ApplicationWindow | None = None
        self.toast_overlay: Adw.ToastOverlay | None = None
        self.messages_box: Gtk.Box | None = None
        self.scroller: Gtk.ScrolledWindow | None = None
        self.input: Gtk.TextView | None = None
        self.input_buffer: Gtk.TextBuffer | None = None
        self.input_scroll: Gtk.ScrolledWindow | None = None
        self.char_count_label: Gtk.Label | None = None
        self.send_button: Gtk.Button | None = None
        self.cancel_button: Gtk.Button | None = None
        self.spinner: Gtk.Spinner | None = None
        self.window_title: Adw.WindowTitle | None = None
        self.status_page: Adw.StatusPage | None = None
        self.banner: Adw.Banner | None = None
        
        self._last_status: dict = {}
        self._voice_enabled = True
        self._cancel_requested = False
        self._is_generating = False
        self._autostart_mode = False
        self._sidebar_visible = True
        self._seen_admin_action_ids: set[str] = set()
        self._seen_system_alert_ids: set[str] = set()
        self._seen_event_keys: set[str] = set()
        self._events_polling = False
        self.sidebar_scroll: Gtk.ScrolledWindow | None = None
        self._client_id = os.getenv("NEXUS_GTK_CLIENT_ID", "nexus_gtk_chat").strip() or "nexus_gtk_chat"
        self._session_id = os.getenv("NEXUS_GTK_SESSION_ID") or datetime.now().strftime("gtk-%Y%m%d-%H%M%S")
        self._history_db = os.path.join(
            os.getenv("XDG_DATA_HOME", os.path.expanduser("~/.local/share")),
            "nexus",
            "gtk_conversations.sqlite",
        )
        self._init_history_db()

    def do_command_line(self, command_line) -> int:
        args = command_line.get_arguments()
        self._autostart_mode = "--autostart" in args
        self.activate()
        return 0

    def do_activate(self) -> None:
        if self.window is None:
            self.window = self._build_window()
            self._apply_theme()
            self._check_status()
            
            # Live telemetry polling every 2 seconds
            GLib.timeout_add(2000, self._poll_status)
            GLib.timeout_add(650, self._poll_agent_events)
            
            if self._autostart_mode:
                GLib.timeout_add(1500, self._trigger_autostart_greeting)
            
            # Contextual Placeholder Timer
            GLib.timeout_add_seconds(15, self._update_contextual_placeholder)
                
        self.window.present()
        start_approval_listener_glib()

    def _apply_theme(self) -> None:
        style_manager = Adw.StyleManager.get_default()
        theme = os.getenv("NEXUS_GTK_THEME", "dark").lower()
        if theme == "dark":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_DARK)
        elif theme == "light":
            style_manager.set_color_scheme(Adw.ColorScheme.PREFER_LIGHT)
        else:
            style_manager.set_color_scheme(Adw.ColorScheme.DEFAULT)

    def _build_window(self) -> Adw.ApplicationWindow:
        self._install_css()

        window = Adw.ApplicationWindow(application=self)
        window.set_default_size(1100, 760)
        window.add_css_class("nexus-window")
        
        # Keyboard shortcuts
        key_ctrl = Gtk.EventControllerKey.new()
        key_ctrl.connect("key-pressed", self._on_key_press)
        window.add_controller(key_ctrl)

        # Main overlay for Toasts
        self.toast_overlay = Adw.ToastOverlay()
        window.set_content(self.toast_overlay)

        # Main vertical box
        self.main_container = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self.toast_overlay.set_child(self.main_container)

        # SIDEBAR (Telemetria Premium)
        sidebar_scroll = Gtk.ScrolledWindow()
        self.sidebar_scroll = sidebar_scroll
        sidebar_scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        sidebar_scroll.set_size_request(240, -1)
        sidebar_scroll.add_css_class("sidebar-scroll")

        self.sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        self.sidebar.add_css_class("sidebar-panel")
        self.sidebar.set_margin_start(14)
        self.sidebar.set_margin_end(14)
        self.sidebar.set_margin_top(14)
        self.sidebar.set_margin_bottom(14)
        sidebar_scroll.set_child(self.sidebar)
        
        # Logo / Branding
        brand_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        brand_title = Gtk.Label(label="NEXUS")
        brand_title.add_css_class("sidebar-brand")
        brand_title.set_halign(Gtk.Align.START)
        brand_sub = Gtk.Label(label="Cognitive OS v3.1")
        brand_sub.add_css_class("sidebar-brand-sub")
        brand_sub.set_halign(Gtk.Align.START)
        brand_box.append(brand_title)
        brand_box.append(brand_sub)
        self.sidebar.append(brand_box)

        sep1 = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep1.add_css_class("sidebar-sep")
        self.sidebar.append(sep1)

        # -- SYSTEM TELEMETRY --
        tel_title = Gtk.Label(label="TELEMETRIA")
        tel_title.add_css_class("sidebar-section-title")
        tel_title.set_halign(Gtk.Align.START)
        self.sidebar.append(tel_title)

        self.cpu_label = Gtk.Label(label="CPU   ·  0%")
        self.cpu_label.add_css_class("sidebar-metric")
        self.cpu_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.cpu_label)

        self.cpu_level = Gtk.LevelBar()
        self.cpu_level.set_min_value(0)
        self.cpu_level.set_max_value(100)
        self.cpu_level.set_value(0)
        self.cpu_level.add_css_class("metric-bar")
        self.sidebar.append(self.cpu_level)

        self.ram_label = Gtk.Label(label="RAM   ·  0%")
        self.ram_label.add_css_class("sidebar-metric")
        self.ram_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.ram_label)

        self.ram_level = Gtk.LevelBar()
        self.ram_level.set_min_value(0)
        self.ram_level.set_max_value(100)
        self.ram_level.set_value(0)
        self.ram_level.add_css_class("metric-bar")
        self.sidebar.append(self.ram_level)

        sep2 = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep2.add_css_class("sidebar-sep")
        self.sidebar.append(sep2)

        # -- COGNITIVE STATE --
        cog_title = Gtk.Label(label="ESTADO COGNITIVO")
        cog_title.add_css_class("sidebar-section-title")
        cog_title.set_halign(Gtk.Align.START)
        self.sidebar.append(cog_title)

        self.mode_label = Gtk.Label(label="Modo: BALANCED")
        self.mode_label.add_css_class("sidebar-value")
        self.mode_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.mode_label)

        self.context_label = Gtk.Label(label="Foco: IDLE")
        self.context_label.add_css_class("sidebar-value")
        self.context_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.context_label)

        self.autonomy_label = Gtk.Label(label="Autonomia: GUARDED")
        self.autonomy_label.add_css_class("sidebar-value")
        self.autonomy_label.set_halign(Gtk.Align.START)
        self.sidebar.append(self.autonomy_label)

        sep3 = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep3.add_css_class("sidebar-sep")
        self.sidebar.append(sep3)

        # -- AGENT STATUS --
        agent_title = Gtk.Label(label="AGENTES")
        agent_title.add_css_class("sidebar-section-title")
        agent_title.set_halign(Gtk.Align.START)
        self.sidebar.append(agent_title)

        agents = [
            ("Strategist", "●", "agent-online"),
            ("Operator", "●", "agent-online"),
            ("Critic", "●", "agent-online"),
            ("RootDaemon", "●", "agent-online"),
            ("EventBus", "●", "agent-online"),
        ]
        for name, icon, css_cls in agents:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            dot = Gtk.Label(label=icon)
            dot.add_css_class(css_cls)
            lbl = Gtk.Label(label=name)
            lbl.add_css_class("sidebar-agent-name")
            row.append(dot)
            row.append(lbl)
            self.sidebar.append(row)

        sep4 = Gtk.Separator(orientation=Gtk.Orientation.HORIZONTAL)
        sep4.add_css_class("sidebar-sep")
        self.sidebar.append(sep4)

        # -- ARCHITECTURE --
        arch_title = Gtk.Label(label="ARQUITETURA")
        arch_title.add_css_class("sidebar-section-title")
        arch_title.set_halign(Gtk.Align.START)
        self.sidebar.append(arch_title)

        arch_items = [
            "Loop Cognitivo Adaptativo",
            "Conversação Anti-Concat",
            "Self-Improvement Pipeline",
            "ResourceGovernor Ativo",
            "PrivacyGuard Shield",
        ]
        for item in arch_items:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
